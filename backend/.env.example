# Copy this file to backend/.env and replace the placeholder values.
# scripts/install_backend.sh can also generate backend/.env for you.

VOICE_AGENT_API_TOKEN=replace-me-with-a-random-token
VOICE_AGENT_HOST=127.0.0.1
VOICE_AGENT_PORT=8000
VOICE_AGENT_SECURITY_MODE=safe
VOICE_AGENT_DEFAULT_EXECUTOR=codex
VOICE_AGENT_CODEX_BINARY=codex
VOICE_AGENT_CODEX_HOME=~/.codex
VOICE_AGENT_CODEX_UNRESTRICTED=false
VOICE_AGENT_CODEX_ENABLE_WEB_SEARCH=true
VOICE_AGENT_CODEX_GUARDRAILS=warn
VOICE_AGENT_CODEX_DANGEROUS_CONFIRM_TOKEN=[allow-dangerous]
VOICE_AGENT_CODEX_USE_CONTEXT=true
VOICE_AGENT_CODEX_CONTEXT_FILE=AGENT_CONTEXT.md
VOICE_AGENT_CLAUDE_BINARY=claude
VOICE_AGENT_ALLOW_ABSOLUTE_FILE_READS=false
VOICE_AGENT_PLAYWRIGHT_OUTPUT_DIR=data/playwright
VOICE_AGENT_PLAYWRIGHT_USER_DATA_DIR=data/playwright-profile
VOICE_AGENT_PAIR_CODE_TTL_MIN=30
VOICE_AGENT_TRANSCRIBE_PROVIDER=openai
VOICE_AGENT_DB_PATH=data/runs.db

# Optional overrides:
# VOICE_AGENT_CODEX_MODEL=gpt-5.1
# VOICE_AGENT_CLAUDE_MODEL=sonnet
# VOICE_AGENT_TRANSCRIBE_MODEL=whisper-1
# VOICE_AGENT_TRANSCRIBE_MOCK_TEXT=hello from audio
# OPENAI_API_KEY=sk-...
