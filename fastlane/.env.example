IOS_APP_IDENTIFIER=com.vemundss.voiceagentapp
APPLE_DEVELOPER_TEAM_ID=
APP_STORE_CONNECT_TEAM_ID=

# Preferred: Fastlane JSON API key file
APP_STORE_CONNECT_API_KEY_JSON_PATH=/absolute/path/to/AuthKey.json

# Alternative: raw App Store Connect API key values
APP_STORE_CONNECT_API_KEY_KEY_ID=
APP_STORE_CONNECT_API_KEY_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8

# Optional if you want Fastlane to fall back to Apple ID auth locally
APPLE_ID=
