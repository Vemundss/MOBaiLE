#!/usr/bin/env bash
set -euo pipefail

resolve_repo_root() {
  if [[ -n "${MOBAILE_REPO_ROOT:-}" ]]; then
    printf "%s\n" "${MOBAILE_REPO_ROOT}"
    return
  fi

  python3 - "${BASH_SOURCE[0]}" << 'PY'
from pathlib import Path
import sys

print(Path(sys.argv[1]).resolve().parent.parent)
PY
}

usage() {
  cat << 'EOF'
Usage: mobaile [command]

Commands:
  status   Show backend status and pairing readiness
  setup    Open the computer-local setup page with QR and readiness checks
  check    Preflight install, dependency, service, and pairing readiness
           Use `mobaile check --json` for machine-readable output
  ready    Run the guided high-autonomy readiness flow
  autonomy Provision browser/desktop automation for more unattended work
  doctor   Check service, pairing, QR, phone URLs, and executor readiness
  first-run
           Run a tiny starter task in ~/MOBaiLE-playground
  demo     Export a sanitized Markdown or JSON demo replay
  repair   Refresh pairing, restart the service when installed, then run doctor
  pair     Generate or surface the pairing QR image
  update   Check for or install newer MOBaiLE updates
  uninstall
           Stop MOBaiLE services and optionally delete local MOBaiLE data
  logs     Show backend service logs
  restart  Restart the backend service
  start    Start the backend service
  stop     Stop the backend service
  awake    Keep this Mac reachable while logged in (macOS)
  awake-status
           Show keep-awake launch agent state (macOS)
  sleep    Remove MOBaiLE's keep-awake launch agent (macOS)
  config   Print important config paths and current values
  help     Show this help
EOF
}

format_command() {
  local formatted=""
  local arg
  for arg in "$@"; do
    if [[ -n "${formatted}" ]]; then
      formatted+=" "
    fi
    printf -v arg "%q" "${arg}"
    formatted+="${arg}"
  done
  printf "%s\n" "${formatted}"
}

read_env_value() {
  local env_file="$1"
  local key="$2"
  local default_value="${3:-}"

  python3 - "${env_file}" "${key}" "${default_value}" << 'PY'
from pathlib import Path
import sys

env_path = Path(sys.argv[1])
target_key = sys.argv[2]
default_value = sys.argv[3]

if not env_path.exists():
    print(default_value)
    raise SystemExit(0)

value = default_value
for line in env_path.read_text(encoding="utf-8").splitlines():
    stripped = line.strip()
    if not stripped or stripped.startswith("#") or "=" not in line:
        continue
    key, raw_value = line.split("=", 1)
    if key.strip() != target_key:
        continue
    value = raw_value.strip().strip("\"'")

print(value)
PY
}

path_presence_label() {
  local path="$1"
  [[ -f "${path}" ]] && printf "(present)" || printf "(missing)"
}

same_path() {
  local left="$1"
  local right="$2"

  python3 - "${left}" "${right}" << 'PY'
from pathlib import Path
import sys

left = Path(sys.argv[1]).expanduser().resolve()
right = Path(sys.argv[2]).expanduser().resolve()
print("yes" if left == right else "no")
PY
}

runtime_env_drift_messages() {
  local checkout_env="$1"
  local active_env="$2"
  local drift=0
  local key checkout_value active_value

  if [[ "$(same_path "${checkout_env}" "${active_env}")" == "yes" ]]; then
    return 0
  fi

  if [[ ! -f "${checkout_env}" ]]; then
    echo "[warn] Checkout env is missing, so active runtime config cannot be compared: ${checkout_env}"
    return 1
  fi

  if [[ ! -f "${active_env}" ]]; then
    echo "[warn] Active runtime env is missing; run mobaile restart to sync checkout config: ${active_env}"
    return 1
  fi

  for key in \
    VOICE_AGENT_SECURITY_MODE \
    VOICE_AGENT_CODEX_UNRESTRICTED \
    VOICE_AGENT_ALLOW_ABSOLUTE_FILE_READS \
    VOICE_AGENT_DEFAULT_EXECUTOR \
    VOICE_AGENT_PHONE_ACCESS_MODE; do
    checkout_value="$(read_env_value "${checkout_env}" "${key}" "<unset>")"
    active_value="$(read_env_value "${active_env}" "${key}" "<unset>")"
    if [[ "${checkout_value}" != "${active_value}" ]]; then
      echo "[warn] Active runtime env differs from checkout for ${key}: checkout=${checkout_value}, active=${active_value}"
      drift=1
    fi
  done

  if [[ "${drift}" -ne 0 ]]; then
    echo "[warn] Run mobaile restart so the installed backend runtime uses the checkout config."
    return 1
  fi

  return 0
}

runtime_env_drift_output() {
  local repo_root="$1"
  local active_backend="$2"
  local checkout_env="${repo_root}/backend/.env"
  local active_env="${active_backend}/.env"

  runtime_env_drift_messages "${checkout_env}" "${active_env}" || true
}

read_pairing_value() {
  local pairing_file="$1"
  local field_name="$2"
  local default_value="${3:-}"

  python3 - "${pairing_file}" "${field_name}" "${default_value}" << 'PY'
import json
from pathlib import Path
import sys

pairing_path = Path(sys.argv[1])
field_name = sys.argv[2]
default_value = sys.argv[3]

if not pairing_path.exists():
    print(default_value)
    raise SystemExit(0)

try:
    payload = json.loads(pairing_path.read_text(encoding="utf-8"))
except json.JSONDecodeError:
    print(default_value)
    raise SystemExit(0)

value = payload.get(field_name, default_value)
if value is None:
    value = default_value

print(str(value))
PY
}

friendly_security_label() {
  case "$1" in
    full-access) printf "Full Access\n" ;;
    *) printf "Safe\n" ;;
  esac
}

is_public_https_url() {
  case "$1" in
    https://*) return 0 ;;
    *) return 1 ;;
  esac
}

friendly_phone_access_label() {
  local phone_access_mode="$1"
  local public_server_url="${2:-}"
  local pairing_server_url="${3:-}"

  case "${phone_access_mode}" in
    wifi) printf "On this Wi-Fi\n" ;;
    local) printf "This computer only\n" ;;
    *)
      if is_public_https_url "${public_server_url}" || is_public_https_url "${pairing_server_url}"; then
        printf "Public URL\n"
      else
        printf "Anywhere with Tailscale\n"
      fi
      ;;
  esac
}

service_script_path() {
  local repo_root="$1"

  case "$(uname -s)" in
    Darwin) printf "%s\n" "${repo_root}/scripts/service_macos.sh" ;;
    Linux) printf "%s\n" "${repo_root}/scripts/service_linux.sh" ;;
    *)
      echo "Unsupported platform: $(uname -s)" >&2
      exit 1
      ;;
  esac
}

service_install_preference() {
  case "$(uname -s)" in
    Darwin)
      [[ -f "${HOME}/Library/LaunchAgents/com.mobile.voiceagent.backend.plist" ]] && printf "yes\n" || printf "no\n"
      ;;
    Linux)
      [[ -f "${HOME}/.config/systemd/user/mobaile-backend.service" ]] && printf "yes\n" || printf "no\n"
      ;;
    *)
      printf "no\n"
      ;;
  esac
}

keep_awake_install_preference() {
  case "$(uname -s)" in
    Darwin)
      [[ -f "${HOME}/Library/LaunchAgents/com.mobile.voiceagent.keepawake.plist" ]] && printf "yes\n" || printf "no\n"
      ;;
    *)
      printf "no\n"
      ;;
  esac
}

runtime_backend_dir() {
  if [[ -n "${MOBAILE_TEST_RUNTIME_BACKEND_DIR:-}" ]]; then
    printf "%s\n" "${MOBAILE_TEST_RUNTIME_BACKEND_DIR}"
    return
  fi

  case "$(uname -s)" in
    Darwin) printf "%s\n" "${HOME}/Library/Application Support/MOBaiLE/backend-runtime" ;;
    Linux) printf "%s\n" "${HOME}/.local/share/MOBaiLE/backend-runtime" ;;
    *) printf "\n" ;;
  esac
}

runtime_data_root() {
  if [[ -n "${MOBAILE_TEST_RUNTIME_DATA_ROOT:-}" ]]; then
    printf "%s\n" "${MOBAILE_TEST_RUNTIME_DATA_ROOT}"
    return
  fi

  case "$(uname -s)" in
    Darwin) printf "%s\n" "${HOME}/Library/Application Support/MOBaiLE" ;;
    Linux) printf "%s\n" "${HOME}/.local/share/MOBaiLE" ;;
    *) printf "\n" ;;
  esac
}

active_backend_dir() {
  local repo_root="$1"
  local runtime_dir

  if [[ -n "${MOBAILE_TEST_ACTIVE_BACKEND_DIR:-}" ]]; then
    printf "%s\n" "${MOBAILE_TEST_ACTIVE_BACKEND_DIR}"
    return
  fi

  runtime_dir="$(runtime_backend_dir)"
  if [[ -n "${runtime_dir}" ]] && [[ -d "${runtime_dir}" ]] && [[ "$(service_install_preference)" == "yes" ]]; then
    printf "%s\n" "${runtime_dir}"
    return
  fi

  printf "%s\n" "${repo_root}/backend"
}

git_checkout_or_fail() {
  local repo_root="$1"
  if ! command -v git > /dev/null 2>&1; then
    echo "git is required for mobaile update." >&2
    exit 1
  fi
  if [[ ! -d "${repo_root}/.git" ]]; then
    echo "mobaile update only works from a git checkout." >&2
    exit 1
  fi
}

git_current_branch() {
  local repo_root="$1"
  git -C "${repo_root}" branch --show-current 2> /dev/null
}

git_origin_url() {
  local repo_root="$1"
  git -C "${repo_root}" remote get-url origin 2> /dev/null || true
}

remote_is_update_source() {
  local remote_url="$1"

  if [[ "${MOBAILE_TEST_ALLOW_ANY_UPDATE_REMOTE:-0}" == "1" ]]; then
    return 0
  fi

  case "${remote_url}" in
    https://github.com/Vemundss/mobaile-backend.git | https://github.com/vemundss/mobaile-backend.git | git@github.com:Vemundss/mobaile-backend.git | git@github.com:vemundss/mobaile-backend.git | ssh://git@github.com/Vemundss/mobaile-backend.git | ssh://git@github.com/vemundss/mobaile-backend.git | https://github.com/Vemundss/mobaile.git | https://github.com/vemundss/mobaile.git | git@github.com:Vemundss/mobaile.git | git@github.com:vemundss/mobaile.git | ssh://git@github.com/Vemundss/mobaile.git | ssh://git@github.com/vemundss/mobaile.git | https://github.com/Vemundss/MOBaiLE.git | https://github.com/vemundss/MOBaiLE.git | git@github.com:Vemundss/MOBaiLE.git | git@github.com:vemundss/MOBaiLE.git | ssh://git@github.com/Vemundss/MOBaiLE.git | ssh://git@github.com/vemundss/MOBaiLE.git)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

git_short_ref() {
  local repo_root="$1"
  local ref="$2"
  git -C "${repo_root}" rev-parse --short "${ref}" 2> /dev/null
}

git_worktree_dirty() {
  local repo_root="$1"
  if [[ -n "$(git -C "${repo_root}" status --short 2> /dev/null)" ]]; then
    return 0
  fi
  return 1
}

fetch_update_refs() {
  local repo_root="$1"
  git -C "${repo_root}" fetch --all --prune > /dev/null 2>&1
}

print_update_status() {
  local repo_root="$1"
  local branch="$2"
  local local_ref="$3"
  local remote_ref="$4"

  echo "Current branch: ${branch}"
  echo "Current version: ${local_ref}"
  echo "Latest main: ${remote_ref}"

  if [[ "${local_ref}" == "${remote_ref}" ]]; then
    echo "MOBaiLE is up to date."
  else
    echo "Update available."
  fi
}

service_state_label() {
  local repo_root="$1"
  local override="${MOBAILE_TEST_SERVICE_STATE:-}"

  if [[ -n "${override}" ]]; then
    case "${override}" in
      running | started | active) printf "Running\n" ;;
      *) printf "Stopped\n" ;;
    esac
    return
  fi

  local service_script
  service_script="$(service_script_path "${repo_root}")"
  if [[ ! -f "${service_script}" ]]; then
    printf "Stopped\n"
    return
  fi

  local status_output lowered
  status_output="$(bash "${service_script}" status 2>&1 || true)"
  lowered="$(printf "%s" "${status_output}" | tr '[:upper:]' '[:lower:]')"

  if [[ "${lowered}" == *"running"* ]] || [[ "${lowered}" == *"active"* ]] || [[ "${lowered}" == *"pid ="* ]] || [[ "${lowered}" == *"state = running"* ]]; then
    printf "Running\n"
    return
  fi

  if [[ "${lowered}" == *" is not loaded"* ]] || [[ "${lowered}" == *"could not find service"* ]] || [[ "${lowered}" == *"could not be found"* ]] || [[ "${lowered}" == *"state = exited"* ]] || [[ "${lowered}" == *"state = suspended"* ]] || [[ "${lowered}" == *"failed"* ]] || [[ "${lowered}" == *"dead"* ]]; then
    printf "Stopped\n"
    return
  fi

  printf "Stopped\n"
}

keep_awake_state_label() {
  local repo_root="$1"
  local override="${MOBAILE_TEST_KEEP_AWAKE_STATE:-}"

  if [[ "$(uname -s)" != "Darwin" ]]; then
    printf "Unsupported\n"
    return
  fi

  if [[ -n "${override}" ]]; then
    case "${override}" in
      running | started | active) printf "Running\n" ;;
      *) printf "Stopped\n" ;;
    esac
    return
  fi

  local service_script
  service_script="$(service_script_path "${repo_root}")"
  if [[ ! -f "${service_script}" ]]; then
    printf "Stopped\n"
    return
  fi

  local status_output lowered
  status_output="$(bash "${service_script}" keep-awake-status 2>&1 || true)"
  lowered="$(printf "%s" "${status_output}" | tr '[:upper:]' '[:lower:]')"

  if [[ "${lowered}" == *"running"* ]] || [[ "${lowered}" == *"active"* ]] || [[ "${lowered}" == *"pid ="* ]] || [[ "${lowered}" == *"state = running"* ]]; then
    printf "Running\n"
    return
  fi

  printf "Stopped\n"
}

resolve_executable_path() {
  local binary="$1"

  if [[ "${binary}" == */* ]]; then
    if [[ -x "${binary}" ]]; then
      printf "%s\n" "${binary}"
      return 0
    fi
    return 1
  fi

  command -v "${binary}" 2> /dev/null
}

doctor_codex_binary_check() {
  local env_file="$1"
  local configured_executor binary executable version lowered_executor

  configured_executor="$(read_env_value "${env_file}" "VOICE_AGENT_DEFAULT_EXECUTOR" "codex")"
  lowered_executor="$(printf "%s" "${configured_executor}" | tr '[:upper:]' '[:lower:]')"
  if [[ "${lowered_executor}" == "local" ]]; then
    lowered_executor="shell"
  fi
  case "${lowered_executor}" in
    shell | codex | claude) ;;
    *) lowered_executor="codex" ;;
  esac

  binary="$(read_env_value "${env_file}" "VOICE_AGENT_CODEX_BINARY" "codex")"

  if executable="$(resolve_executable_path "${binary}")"; then
    version="$("${executable}" --version 2>&1 | head -n 1 || true)"
    if [[ -n "${version}" ]]; then
      echo "[ok] Codex binary is available: ${version}"
    else
      echo "[ok] Codex binary is available: ${executable}"
    fi
    if [[ "${lowered_executor}" != "codex" ]]; then
      echo "[warn] Default executor is ${lowered_executor}, not Codex"
    fi
    return 0
  fi

  if [[ "${lowered_executor}" == "codex" ]]; then
    echo "[fail] Default executor is Codex, but the Codex binary is unavailable: ${binary}"
    return 1
  fi

  echo "[warn] Codex binary is unavailable: ${binary}"
  echo "[warn] Default executor is ${lowered_executor}, not Codex"
  return 0
}

pairing_state_code() {
  local pairing_file="$1"

  python3 - "${pairing_file}" << 'PY'
import json
from datetime import datetime, timezone
from pathlib import Path
import sys

pairing_path = Path(sys.argv[1])
if not pairing_path.exists():
    print("missing")
    raise SystemExit(0)

try:
    payload = json.loads(pairing_path.read_text(encoding="utf-8"))
except json.JSONDecodeError:
    print("missing")
    raise SystemExit(0)

server_url = str(payload.get("server_url", "")).strip()
pair_code = str(payload.get("pair_code", "")).strip()
expires_at = str(payload.get("pair_code_expires_at", "")).strip()

if not server_url or not pair_code:
    print("missing")
    raise SystemExit(0)

if expires_at:
    try:
        parsed = datetime.fromisoformat(expires_at.replace("Z", "+00:00"))
    except ValueError:
        print("missing")
        raise SystemExit(0)
    if parsed <= datetime.now(timezone.utc):
        print("expired")
        raise SystemExit(0)

print("ready")
PY
}

pairing_qr_path() {
  local backend_dir="$1"
  printf "%s\n" "${MOBAILE_TEST_PAIRING_QR:-${backend_dir}/pairing-qr.png}"
}

pairing_status_label() {
  local pairing_file="$1"
  local pairing_state
  pairing_state="$(pairing_state_code "${pairing_file}")"

  case "${pairing_state}" in
    ready) printf "Ready\n" ;;
    expired) printf "Expired; run mobaile pair\n" ;;
    *) printf "Not ready\n" ;;
  esac
}

pairing_qr_label() {
  local backend_dir="$1"
  local pairing_file="${backend_dir}/pairing.json"
  local qr_path
  local pairing_state
  qr_path="$(pairing_qr_path "${backend_dir}")"
  pairing_state="$(pairing_state_code "${pairing_file}")"

  case "${pairing_state}" in
    ready)
      if [[ -f "${qr_path}" ]]; then
        printf "Ready (%s)\n" "${qr_path}"
      else
        printf "Available via mobaile pair\n"
      fi
      ;;
    expired) printf "Expired; run mobaile pair\n" ;;
    *) printf "Not ready\n" ;;
  esac
}

open_file_if_possible() {
  local path="$1"

  if [[ "${MOBAILE_SKIP_OPEN:-0}" == "1" ]]; then
    return
  fi

  if command -v open > /dev/null 2>&1; then
    open "${path}" > /dev/null 2>&1 || true
    return
  fi

  if command -v xdg-open > /dev/null 2>&1; then
    xdg-open "${path}" > /dev/null 2>&1 || true
  fi
}

status_command() {
  local repo_root="$1"
  local backend_dir
  local env_file
  local pairing_file
  local security_mode phone_access_mode public_server_url server_url drift_output

  backend_dir="$(active_backend_dir "${repo_root}")"
  env_file="${backend_dir}/.env"
  pairing_file="${backend_dir}/pairing.json"

  security_mode="$(read_env_value "${env_file}" "VOICE_AGENT_SECURITY_MODE" "safe")"
  phone_access_mode="$(read_env_value "${env_file}" "VOICE_AGENT_PHONE_ACCESS_MODE" "tailscale")"
  public_server_url="$(read_env_value "${env_file}" "VOICE_AGENT_PUBLIC_SERVER_URL" "")"
  server_url="$(read_pairing_value "${pairing_file}" "server_url" "Not ready")"
  drift_output="$(runtime_env_drift_output "${repo_root}" "${backend_dir}")"

  cat << EOF
MOBaiLE: $(service_state_label "${repo_root}")
Security: $(friendly_security_label "${security_mode}")
Phone access: $(friendly_phone_access_label "${phone_access_mode}" "${public_server_url}" "${server_url}")
Phone pairing: $(pairing_status_label "${pairing_file}")
URL: ${server_url}
Pairing QR: $(pairing_qr_label "${backend_dir}")
EOF
  if [[ -n "${drift_output}" ]]; then
    printf "\n%s\n" "${drift_output}"
  fi
  cat << EOF
Quick actions:
  mobaile check
  mobaile pair
  mobaile first-run
  mobaile demo
  mobaile ready
  mobaile autonomy
  mobaile doctor
  mobaile repair
  mobaile update
  mobaile restart
  mobaile logs
  mobaile config
EOF
}

setup_page_url() {
  local repo_root="$1"
  local backend_dir env_file port
  backend_dir="$(active_backend_dir "${repo_root}")"
  env_file="${backend_dir}/.env"
  port="$(read_env_value "${env_file}" "VOICE_AGENT_PORT" "8000")"
  case "${port}" in
    '' | *[!0-9]*) port="8000" ;;
  esac
  printf "http://127.0.0.1:%s/setup\n" "${port}"
}

setup_command() {
  local repo_root="$1"
  shift || true
  local print_only="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --url)
        print_only="true"
        shift
        ;;
      -h | --help)
        echo "Usage: mobaile setup [--url]"
        return 0
        ;;
      *)
        echo "Unknown setup argument: $1" >&2
        echo "Usage: mobaile setup [--url]" >&2
        return 1
        ;;
    esac
  done

  local url service_state
  url="$(setup_page_url "${repo_root}")"
  if [[ "${print_only}" == "true" ]]; then
    printf "%s\n" "${url}"
    return 0
  fi

  echo "MOBaiLE setup page on this computer: ${url}"
  echo "This URL uses 127.0.0.1, so open it on the backend computer, not on the iPhone."
  service_state="$(service_state_label "${repo_root}")"
  if [[ "${service_state}" != "Running" ]]; then
    echo "Backend service is not running yet. Run mobaile restart if the page does not load."
  fi
  open_file_if_possible "${url}"
}

resolve_backend_path() {
  local backend_dir="$1"
  local raw_value="$2"
  local fallback="$3"

  python3 - "${backend_dir}" "${raw_value}" "${fallback}" << 'PY'
from pathlib import Path
import sys

backend_dir = Path(sys.argv[1]).expanduser().resolve()
raw_value = sys.argv[2].strip() or sys.argv[3].strip()
path = Path(raw_value).expanduser()
if not path.is_absolute():
    path = backend_dir / path
print(path.resolve())
PY
}

open_macos_privacy_panes() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    return
  fi
  if [[ "${MOBAILE_SKIP_OPEN:-0}" == "1" ]]; then
    return
  fi
  if ! command -v open > /dev/null 2>&1; then
    return
  fi

  open "x-apple.systempreferences:com.apple.preference.security?Privacy_Accessibility" > /dev/null 2>&1 || true
  open "x-apple.systempreferences:com.apple.preference.security?Privacy_ScreenCapture" > /dev/null 2>&1 || true
  open "x-apple.systempreferences:com.apple.preference.security?Privacy_Automation" > /dev/null 2>&1 || true
}

autonomy_usage() {
  cat << 'EOF'
Usage: mobaile autonomy [options]

Options:
  --deep                 Run backend capability warmup after provisioning
  --open-permissions     Open macOS privacy panes for manual approval
  --no-open-permissions  Do not open System Settings
  --skip-browser-warmup  Skip Playwright browser runtime install warmup
  --force-mcp            Replace existing Codex MCP entries with MOBaiLE defaults
  --dry-run              Print the provisioning command without running it
EOF
}

autonomy_command() {
  local repo_root="$1"
  shift || true
  local deep="false"
  local open_permissions="false"
  local skip_browser_warmup="false"
  local force_mcp="false"
  local dry_run="false"
  local backend_dir env_file security_mode codex_home_raw playwright_output_raw playwright_profile_raw
  local codex_home playwright_output playwright_profile

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --deep)
        deep="true"
        shift
        ;;
      --open-permissions)
        open_permissions="true"
        shift
        ;;
      --no-open-permissions)
        open_permissions="false"
        shift
        ;;
      --skip-browser-warmup)
        skip_browser_warmup="true"
        shift
        ;;
      --force-mcp)
        force_mcp="true"
        shift
        ;;
      --dry-run)
        dry_run="true"
        shift
        ;;
      -h | --help)
        autonomy_usage
        return 0
        ;;
      *)
        autonomy_usage >&2
        echo "Unknown autonomy argument: $1" >&2
        return 1
        ;;
    esac
  done

  backend_dir="$(active_backend_dir "${repo_root}")"
  env_file="${backend_dir}/.env"
  security_mode="$(read_env_value "${env_file}" "VOICE_AGENT_SECURITY_MODE" "full-access")"
  case "${security_mode}" in
    full-access | safe) ;;
    *) security_mode="safe" ;;
  esac

  codex_home_raw="$(read_env_value "${env_file}" "VOICE_AGENT_CODEX_HOME" "${HOME}/.codex")"
  playwright_output_raw="$(read_env_value "${env_file}" "VOICE_AGENT_PLAYWRIGHT_OUTPUT_DIR" "data/playwright")"
  playwright_profile_raw="$(read_env_value "${env_file}" "VOICE_AGENT_PLAYWRIGHT_USER_DATA_DIR" "data/playwright-profile")"
  codex_home="$(resolve_backend_path "${backend_dir}" "${codex_home_raw}" "${HOME}/.codex")"
  playwright_output="$(resolve_backend_path "${backend_dir}" "${playwright_output_raw}" "data/playwright")"
  playwright_profile="$(resolve_backend_path "${backend_dir}" "${playwright_profile_raw}" "data/playwright-profile")"

  local provision_cmd=(
    python3 "${repo_root}/scripts/provision_codex_autonomy.py"
    --mode "${security_mode}"
    --codex-home "${codex_home}"
    --playwright-output-dir "${playwright_output}"
    --playwright-user-data-dir "${playwright_profile}"
  )
  if [[ "${skip_browser_warmup}" == "true" ]]; then
    provision_cmd+=(--skip-browser-warmup)
  fi
  if [[ "${force_mcp}" == "true" ]]; then
    provision_cmd+=(--force-mcp)
  fi

  echo "MOBaiLE autonomy setup"
  echo "Active backend: ${backend_dir}"
  echo "Security mode: ${security_mode}"
  echo "Browser profile: ${playwright_profile}"
  echo

  if [[ "${dry_run}" == "true" ]]; then
    echo "Provision command:"
    echo "  $(format_command "${provision_cmd[@]}")"
  else
    "${provision_cmd[@]}"
  fi

  if [[ "${open_permissions}" == "true" ]]; then
    if [[ "${dry_run}" == "true" ]]; then
      echo "Would open macOS Accessibility, Screen Recording, and Automation privacy panes."
    else
      open_macos_privacy_panes
    fi
  elif [[ "$(uname -s)" == "Darwin" ]]; then
    echo
    echo "macOS privacy approvals are still manual when needed:"
    echo "  mobaile ready --open-permissions --open-setup"
  fi

  if [[ "${deep}" != "true" ]]; then
    echo
    echo "Deep readiness: skipped. Run with --deep to verify backend browser/desktop permissions."
    return 0
  fi

  if [[ "${dry_run}" == "true" ]]; then
    echo "Would run backend capability warmup."
    return 0
  fi

  if [[ "$(service_state_label "${repo_root}")" != "Running" ]]; then
    echo "Deep readiness needs the backend running. Run mobaile restart, then mobaile ready."
    return 1
  fi

  local service_script
  service_script="$(service_script_path "${repo_root}")"
  if [[ ! -f "${service_script}" ]]; then
    echo "Missing service helper: ${service_script}" >&2
    return 1
  fi
  bash "${service_script}" warmup
}

ready_usage() {
  cat << 'EOF'
Usage: mobaile ready [options]

Options:
  --open-permissions     Open macOS privacy panes during the autonomy check
  --no-open-permissions  Do not open System Settings (default)
  --quick                Skip the deep backend capability warmup
  --keep-awake           Install the macOS keep-awake helper (default on macOS)
  --no-keep-awake        Do not change keep-awake state
  --skip-pair            Do not refresh the pairing QR
  --open-setup           Open the computer-local setup page after checks
  --no-open-setup        Do not open the setup page (default)
  --skip-check           Skip the final mobaile check
  --dry-run              Print commands without changing the host
EOF
}

ready_command() {
  local repo_root="$1"
  shift || true
  local open_permissions="false"
  local deep="true"
  local keep_awake="auto"
  local refresh_pairing="true"
  local open_setup="false"
  local run_check="true"
  local dry_run="false"
  local check_needs_action="false"
  local failures=0
  local service_script service_state

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --open-permissions)
        open_permissions="true"
        shift
        ;;
      --no-open-permissions)
        open_permissions="false"
        shift
        ;;
      --quick)
        deep="false"
        shift
        ;;
      --keep-awake)
        keep_awake="yes"
        shift
        ;;
      --no-keep-awake)
        keep_awake="no"
        shift
        ;;
      --skip-pair)
        refresh_pairing="false"
        shift
        ;;
      --open-setup)
        open_setup="true"
        shift
        ;;
      --no-open-setup)
        open_setup="false"
        shift
        ;;
      --skip-check)
        run_check="false"
        shift
        ;;
      --dry-run)
        dry_run="true"
        shift
        ;;
      -h | --help)
        ready_usage
        return 0
        ;;
      *)
        ready_usage >&2
        echo "Unknown ready argument: $1" >&2
        return 1
        ;;
    esac
  done

  echo "MOBaiLE high-autonomy setup"
  echo "Automatic host steps run here; CLI sign-in, Tailscale sign-in, and OS privacy approval remain manual."

  service_script="$(service_script_path "${repo_root}")"
  service_state="$(service_state_label "${repo_root}")"
  echo
  if [[ "$(service_install_preference)" == "yes" ]]; then
    if [[ "${service_state}" == "Running" ]]; then
      echo "Backend service: running"
    elif [[ "${dry_run}" == "true" ]]; then
      echo "Would restart backend service:"
      echo "  $(format_command bash "${service_script}" restart)"
    elif [[ -f "${service_script}" ]]; then
      echo "Restarting backend service..."
      if ! bash "${service_script}" restart; then
        echo "Backend restart reported a problem." >&2
        failures=$((failures + 1))
      fi
    else
      echo "Service helper is missing: ${service_script}" >&2
      failures=$((failures + 1))
    fi
  else
    echo "Backend service: not installed. Re-run the installer with --background-service yes for always-on phone control."
  fi

  if [[ "$(uname -s)" == "Darwin" ]]; then
    echo
    if [[ "${keep_awake}" != "no" ]]; then
      if [[ "${dry_run}" == "true" ]]; then
        echo "Would install the macOS keep-awake helper:"
        echo "  $(format_command bash "${service_script}" keep-awake-install)"
      elif [[ -f "${service_script}" ]]; then
        echo "Installing macOS keep-awake helper..."
        if ! bash "${service_script}" keep-awake-install; then
          echo "Keep-awake setup reported a problem." >&2
          failures=$((failures + 1))
        fi
      else
        echo "Service helper is missing: ${service_script}" >&2
        failures=$((failures + 1))
      fi
    else
      echo "Keep-awake helper: skipped"
    fi
  fi

  local autonomy_args=()
  if [[ "${deep}" == "true" ]]; then
    autonomy_args+=(--deep)
  fi
  if [[ "${open_permissions}" == "true" ]]; then
    autonomy_args+=(--open-permissions)
  else
    autonomy_args+=(--no-open-permissions)
  fi
  if [[ "${dry_run}" == "true" ]]; then
    autonomy_args+=(--dry-run)
  fi

  echo
  if ! autonomy_command "${repo_root}" "${autonomy_args[@]}"; then
    failures=$((failures + 1))
  fi

  echo
  if [[ "${refresh_pairing}" == "true" ]]; then
    if [[ "${dry_run}" == "true" ]]; then
      echo "Would refresh pairing QR:"
      echo "  $(format_command bash "${repo_root}/scripts/mobaile" pair)"
    elif [[ "${open_setup}" == "true" ]]; then
      if ! MOBAILE_SKIP_OPEN=1 pair_command "${repo_root}"; then
        failures=$((failures + 1))
      fi
    elif ! pair_command "${repo_root}"; then
      failures=$((failures + 1))
    fi
  else
    echo "Pairing QR refresh: skipped"
  fi

  echo
  if [[ "${run_check}" == "true" ]]; then
    if [[ "${dry_run}" == "true" ]]; then
      echo "Would run mobaile check."
    elif ! check_command "${repo_root}"; then
      check_needs_action="true"
      failures=$((failures + 1))
    fi
  else
    echo "Final setup check: skipped"
  fi

  if [[ "${check_needs_action}" == "true" ]]; then
    echo
    ready_human_unblock_summary "${repo_root}"
  fi

  echo
  if [[ "${open_setup}" == "true" ]]; then
    if [[ "${dry_run}" == "true" ]]; then
      echo "Would open the computer-local setup page:"
      echo "  $(format_command bash "${repo_root}/scripts/mobaile" setup)"
    elif ! setup_command "${repo_root}"; then
      failures=$((failures + 1))
    fi
  else
    echo "Setup page: run mobaile setup when you want the local QR and checklist."
  fi

  echo
  if [[ "${failures}" -eq 0 ]]; then
    echo "Ready result: ready or waiting on human approval."
    return 0
  fi
  echo "Ready result: needs action"
  return 1
}

CHECK_FAILURES=0

check_ok() {
  echo "[ok] $1"
}

check_info() {
  echo "[info] $1"
}

check_todo() {
  echo "[todo] $1"
  CHECK_FAILURES=$((CHECK_FAILURES + 1))
}

check_cmd_available() {
  local cmd="$1"
  local detail="$2"
  if command -v "${cmd}" > /dev/null 2>&1; then
    check_ok "${cmd} is available"
    return 0
  fi
  check_todo "${detail}"
  return 1
}

check_python_version() {
  local backend_dir="${1:-}"
  local backend_python=""
  local version=""

  if [[ -n "${backend_dir}" ]]; then
    backend_python="${backend_dir}/.venv/bin/python"
  fi

  if [[ -x "${backend_python}" ]]; then
    if version="$(
      "${backend_python}" - << 'PY'
import sys
required = (3, 11)
if sys.version_info < required:
    raise SystemExit(1)
print(".".join(str(part) for part in sys.version_info[:3]))
PY
    )"; then
      check_ok "Backend Python ${version} is ready via uv"
    else
      check_todo "Backend uv environment needs Python 3.11 or newer; run mobaile repair"
    fi
    return
  fi

  if command -v uv > /dev/null 2>&1; then
    check_info "uv is available and can prepare Python 3.11+ for the backend"
  elif command -v python3 > /dev/null 2>&1; then
    check_info "System $(python3 --version 2>&1) is available; MOBaiLE can use uv-managed Python for the backend"
  else
    check_info "The installer can add uv and a backend Python automatically"
  fi
}

codex_login_state() {
  local codex_path="$1"
  local output=""

  output="$("${codex_path}" login status 2>&1 || true)"
  case "$(printf "%s" "${output}" | tr '[:upper:]' '[:lower:]')" in
    *"not logged"* | *"not authenticated"* | *"login required"*)
      printf "todo\n"
      ;;
    *"logged in"*)
      printf "ok\n"
      ;;
    *)
      printf "unknown\n"
      ;;
  esac
}

check_agent_cli() {
  local env_file="$1"
  local codex_binary claude_binary codex_path claude_path agent_ready="false" agent_seen="false" agent_todo=""

  codex_binary="$(read_env_value "${env_file}" "VOICE_AGENT_CODEX_BINARY" "codex")"
  claude_binary="$(read_env_value "${env_file}" "VOICE_AGENT_CLAUDE_BINARY" "claude")"

  if codex_path="$(resolve_executable_path "${codex_binary}")"; then
    agent_seen="true"
    local codex_version codex_state
    codex_version="$("${codex_path}" --version 2>&1 | head -n 1 || printf "%s" "${codex_path}")"
    codex_state="$(codex_login_state "${codex_path}")"
    case "${codex_state}" in
      ok)
        check_ok "Codex CLI is available and logged in: ${codex_version}"
        agent_ready="true"
        ;;
      todo)
        agent_todo="Sign in to Codex CLI for real agent runs"
        ;;
      *)
        check_info "Codex CLI is available, but login status could not be verified: ${codex_version}"
        agent_ready="true"
        ;;
    esac
  fi
  if claude_path="$(resolve_executable_path "${claude_binary}")"; then
    check_ok "Claude CLI is available: ${claude_path}"
    agent_seen="true"
    agent_ready="true"
  fi

  if [[ "${agent_seen}" != "true" ]]; then
    check_todo "Install and sign in to Codex CLI or Claude CLI for real agent runs"
    echo "       Codex CLI: https://developers.openai.com/codex/cli"
  elif [[ "${agent_ready}" != "true" ]]; then
    check_todo "${agent_todo:-No signed-in agent CLI is ready for real agent runs}"
    if [[ "${agent_todo}" == "Sign in to Codex CLI for real agent runs" ]]; then
      echo "       Run: codex login"
    fi
  fi
}

check_autonomy_dependencies() {
  local env_file="$1"
  local security_mode
  security_mode="$(read_env_value "${env_file}" "VOICE_AGENT_SECURITY_MODE" "safe")"

  if [[ "${security_mode}" != "full-access" ]]; then
    return
  fi

  if command -v npx > /dev/null 2>&1; then
    check_ok "npx is available for browser/desktop automation"
  else
    check_info "Node.js/npm is not installed; browser/desktop automation needs npx. Direct shell and agent runs still work."
  fi
}

check_phone_path() {
  local phone_access_mode="$1"
  local public_server_url="$2"

  if [[ "${phone_access_mode}" == "tailscale" && -z "${public_server_url}" ]]; then
    if ! command -v tailscale > /dev/null 2>&1; then
      check_todo "Install Tailscale on this computer and the iPhone for Anywhere mode"
      echo "       Download: https://tailscale.com/download"
      return
    fi
    if tailscale status > /dev/null 2>&1; then
      check_ok "Tailscale is installed and reachable from the CLI"
    else
      check_todo "Tailscale is installed, but it does not look signed in/connected"
      echo "       Open Tailscale and sign in on this computer and the iPhone."
    fi
  elif [[ "${phone_access_mode}" == "wifi" ]]; then
    check_info "Wi-Fi mode does not require Tailscale; cellular use needs Tailscale or public HTTPS"
  elif [[ "${phone_access_mode}" == "local" ]]; then
    check_info "Local mode is for this computer/simulator only"
  elif [[ -n "${public_server_url}" ]]; then
    check_ok "Public HTTPS URL is configured for phone access"
  fi
}

check_pairing_state() {
  local backend_dir="$1"
  local pairing_file="${backend_dir}/pairing.json"
  local qr_path
  local state

  qr_path="$(pairing_qr_path "${backend_dir}")"
  state="$(pairing_state_code "${pairing_file}")"
  case "${state}" in
    ready)
      check_ok "Pairing file has a fresh pair code"
      if [[ -f "${qr_path}" ]]; then
        check_ok "Pairing QR exists: ${qr_path}"
      else
        check_info "Pairing QR can be generated with mobaile pair"
      fi
      ;;
    expired)
      check_todo "Pair code is expired; run mobaile pair"
      ;;
    *)
      check_todo "Pairing is not ready; run mobaile pair after install"
      ;;
  esac
}

check_json_command() {
  local repo_root="$1"
  local backend_dir="$2"
  local env_file="$3"
  local pairing_file="$4"
  local phone_access_mode="$5"
  local public_server_url="$6"
  local server_url="$7"
  local phone_access_label="$8"
  local service_state="$9"
  local pairing_state="${10}"
  local qr_path="${11}"

  CHECK_REPO_ROOT="${repo_root}" \
    CHECK_BACKEND_DIR="${backend_dir}" \
    CHECK_ENV_FILE="${env_file}" \
    CHECK_PAIRING_FILE="${pairing_file}" \
    CHECK_PHONE_ACCESS_MODE="${phone_access_mode}" \
    CHECK_PUBLIC_SERVER_URL="${public_server_url}" \
    CHECK_SERVER_URL="${server_url}" \
    CHECK_PHONE_ACCESS_LABEL="${phone_access_label}" \
    CHECK_SERVICE_STATE="${service_state}" \
    CHECK_PAIRING_STATE="${pairing_state}" \
    CHECK_QR_PATH="${qr_path}" \
    python3 - << 'PY'
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path


def read_env(path: Path, key: str, default: str = "") -> str:
    if not path.exists():
        return default
    for line in path.read_text(encoding="utf-8").splitlines():
        if not line.strip() or line.lstrip().startswith("#") or "=" not in line:
            continue
        raw_key, raw_value = line.split("=", 1)
        if raw_key.strip() == key:
            return raw_value.strip().strip("\"'")
    return default


def resolve_executable(binary: str) -> str:
    if "/" in binary:
        return binary if os.access(binary, os.X_OK) else ""
    return shutil.which(binary) or ""


def codex_login_status(codex_path: str) -> str:
    try:
        result = subprocess.run(
            [codex_path, "login", "status"],
            capture_output=True,
            text=True,
            timeout=3,
            check=False,
        )
    except (OSError, subprocess.SubprocessError):
        return "unknown"
    output = f"{result.stdout}\n{result.stderr}".lower()
    if "not logged" in output or "not authenticated" in output or "login required" in output:
        return "todo"
    if "logged in" in output:
        return "ok"
    return "unknown"


def command_status(command: str) -> bool:
    return shutil.which(command) is not None


def read_python_version(binary: Path):
    result = subprocess.run(
        [str(binary), "-c", "import sys; print('.'.join(str(part) for part in sys.version_info[:3]))"],
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode != 0:
        return None
    raw_version = result.stdout.strip()
    try:
        version = tuple(int(part) for part in raw_version.split(".")[:3])
    except ValueError:
        return None
    if len(version) != 3:
        return None
    return version, raw_version


def add(checks: list[dict[str, str]], check_id: str, status: str, message: str) -> None:
    checks.append({"id": check_id, "status": status, "message": message})


repo_root = os.environ["CHECK_REPO_ROOT"]
backend_dir = os.environ["CHECK_BACKEND_DIR"]
env_file = Path(os.environ["CHECK_ENV_FILE"])
pairing_file = os.environ["CHECK_PAIRING_FILE"]
phone_access_mode = os.environ["CHECK_PHONE_ACCESS_MODE"]
public_server_url = os.environ["CHECK_PUBLIC_SERVER_URL"]
server_url = os.environ["CHECK_SERVER_URL"]
phone_access_label = os.environ["CHECK_PHONE_ACCESS_LABEL"]
service_state = os.environ["CHECK_SERVICE_STATE"]
pairing_state = os.environ["CHECK_PAIRING_STATE"]
qr_path = os.environ["CHECK_QR_PATH"]
checks: list[dict[str, str]] = []

add(checks, "git", "ok" if command_status("git") else "todo", "Git is available" if command_status("git") else "Install Git, then rerun the installer")
add(checks, "curl", "ok" if command_status("curl") else "todo", "curl is available" if command_status("curl") else "Install curl, then rerun the installer")
backend_python = Path(backend_dir) / ".venv" / "bin" / "python"
backend_python_version = read_python_version(backend_python) if backend_python.exists() else None
if backend_python_version is not None and backend_python_version[0] >= (3, 11, 0):
    add(checks, "python", "ok", f"Backend Python {backend_python_version[1]} is ready via uv")
elif backend_python.exists():
    add(checks, "python", "todo", "Backend uv environment needs Python 3.11 or newer; run mobaile repair")
elif command_status("uv"):
    add(checks, "python", "info", "uv is available and can prepare Python 3.11+ for the backend")
elif command_status("python3"):
    system_version = ".".join(str(part) for part in sys.version_info[:3])
    add(checks, "python", "info", f"System Python {system_version} is available; MOBaiLE can use uv-managed Python for the backend")
else:
    add(checks, "python", "info", "The installer can add uv and a backend Python automatically")
add(checks, "uv", "ok" if command_status("uv") else "info", "uv is available" if command_status("uv") else "The MOBaiLE installer can add uv automatically")

codex_binary = read_env(env_file, "VOICE_AGENT_CODEX_BINARY", "codex")
claude_binary = read_env(env_file, "VOICE_AGENT_CLAUDE_BINARY", "claude")
codex_path = resolve_executable(codex_binary)
claude_path = resolve_executable(claude_binary)
agent_ready = False
agent_messages = []
agent_todos = []
if codex_path:
    codex_status = codex_login_status(codex_path)
    if codex_status == "ok":
        agent_ready = True
        agent_messages.append("Codex CLI is available and logged in")
    elif codex_status == "todo":
        agent_todos.append("Sign in to Codex CLI for real agent runs")
    else:
        agent_ready = True
        agent_messages.append("Codex CLI is available, but login status could not be verified")
if claude_path:
    agent_ready = True
    agent_messages.append("Claude CLI is available")
if not codex_path and not claude_path:
    add(checks, "agent_cli", "todo", "Install and sign in to Codex CLI or Claude CLI for real agent runs")
elif not agent_ready:
    add(checks, "agent_cli", "todo", agent_todos[0] if agent_todos else "No signed-in agent CLI is ready for real agent runs")
elif agent_messages:
    add(checks, "agent_cli", "ok", "; ".join(agent_messages))
else:
    pass

if read_env(env_file, "VOICE_AGENT_SECURITY_MODE", "safe") == "full-access":
    add(
        checks,
        "autonomy_npx",
        "ok" if command_status("npx") else "info",
        "npx is available for browser/desktop automation"
        if command_status("npx")
        else "Node.js/npm is not installed; browser/desktop automation needs npx. Direct shell and agent runs still work.",
    )

if phone_access_mode == "tailscale" and not public_server_url:
    if not command_status("tailscale"):
        add(checks, "phone_path", "todo", "Install Tailscale on this computer and the iPhone for Anywhere mode")
    else:
        status = subprocess.run(["tailscale", "status"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)
        add(
            checks,
            "phone_path",
            "ok" if status.returncode == 0 else "todo",
            "Tailscale is installed and reachable from the CLI" if status.returncode == 0 else "Tailscale is installed, but it does not look signed in/connected",
        )
elif phone_access_mode == "wifi":
    add(checks, "phone_path", "info", "Wi-Fi mode does not require Tailscale; cellular use needs Tailscale or public HTTPS")
elif phone_access_mode == "local":
    add(checks, "phone_path", "info", "Local mode is for this computer/simulator only")
else:
    add(checks, "phone_path", "ok", "Public HTTPS URL is configured for phone access")

if service_state == "Running":
    add(checks, "service", "ok", "Backend service is running")
else:
    add(checks, "service", "todo", "Backend service is not running")

if pairing_state == "ready":
    add(checks, "pairing", "ok", "Pairing file has a fresh pair code")
    if Path(qr_path).exists():
        add(checks, "pairing_qr", "ok", f"Pairing QR exists: {qr_path}")
    else:
        add(checks, "pairing_qr", "info", "Pairing QR can be generated with mobaile pair")
elif pairing_state == "expired":
    add(checks, "pairing", "todo", "Pair code is expired; run mobaile pair")
else:
    add(checks, "pairing", "todo", "Pairing is not ready; run mobaile pair after install")

next_actions = [item["message"] for item in checks if item["status"] == "todo"]
payload = {
    "status": "needs_action" if next_actions else "ready",
    "active_backend": backend_dir,
    "repo_root": repo_root,
    "phone_access": {
        "mode": phone_access_mode,
        "label": phone_access_label,
        "server_url": server_url,
    },
    "service_state": service_state,
    "pairing_state": pairing_state,
    "checks": checks,
    "next_actions": next_actions,
}
print(json.dumps(payload, indent=2))
raise SystemExit(1 if next_actions else 0)
PY
}

check_command() {
  local repo_root="$1"
  shift || true
  local output_json="false"
  local backend_dir env_file pairing_file phone_access_mode public_server_url server_url service_state qr_path pairing_state phone_access_label

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        output_json="true"
        shift
        ;;
      -h | --help)
        echo "Usage: mobaile check [--json]"
        return 0
        ;;
      *)
        echo "Unknown check argument: $1" >&2
        echo "Usage: mobaile check [--json]" >&2
        return 1
        ;;
    esac
  done

  CHECK_FAILURES=0
  backend_dir="$(active_backend_dir "${repo_root}")"
  env_file="${backend_dir}/.env"
  pairing_file="${backend_dir}/pairing.json"
  phone_access_mode="$(read_env_value "${env_file}" "VOICE_AGENT_PHONE_ACCESS_MODE" "tailscale")"
  public_server_url="$(read_env_value "${env_file}" "VOICE_AGENT_PUBLIC_SERVER_URL" "")"
  server_url="$(read_pairing_value "${pairing_file}" "server_url" "")"
  service_state="$(service_state_label "${repo_root}")"
  qr_path="$(pairing_qr_path "${backend_dir}")"
  pairing_state="$(pairing_state_code "${pairing_file}")"
  phone_access_label="$(friendly_phone_access_label "${phone_access_mode}" "${public_server_url}" "${server_url}")"

  if [[ "${output_json}" == "true" ]]; then
    check_json_command \
      "${repo_root}" \
      "${backend_dir}" \
      "${env_file}" \
      "${pairing_file}" \
      "${phone_access_mode}" \
      "${public_server_url}" \
      "${server_url}" \
      "${phone_access_label}" \
      "${service_state}" \
      "${pairing_state}" \
      "${qr_path}"
    return
  fi

  echo "MOBaiLE setup check"
  echo "Active backend: ${backend_dir}"
  echo "Phone access: ${phone_access_label} (${phone_access_mode})"
  echo

  check_cmd_available git "Install Git, then rerun the installer" || true
  check_cmd_available curl "Install curl, then rerun the installer" || true
  check_python_version "${backend_dir}"
  if command -v uv > /dev/null 2>&1; then
    check_ok "uv is available"
  else
    check_info "uv is not installed yet; the MOBaiLE installer can add it automatically"
  fi
  check_agent_cli "${env_file}"
  check_autonomy_dependencies "${env_file}"
  check_phone_path "${phone_access_mode}" "${public_server_url}"

  if [[ "${service_state}" == "Running" ]]; then
    check_ok "Backend service is running"
  elif [[ "$(service_install_preference)" == "yes" ]]; then
    check_todo "Backend service is installed but not running; run mobaile restart"
  else
    check_info "Background service is not installed; the recommended installer can add it"
  fi

  check_pairing_state "${backend_dir}"
  if [[ "${service_state}" == "Running" && -f "${pairing_file}" ]] && command -v curl > /dev/null 2>&1; then
    if ! doctor_health_check "${pairing_file}"; then
      CHECK_FAILURES=$((CHECK_FAILURES + 1))
    fi
  fi

  echo
  if [[ "${CHECK_FAILURES}" -eq 0 ]]; then
    echo "Check result: ready"
    return 0
  fi
  echo "Check result: needs action"
  return 1
}

ready_human_unblock_summary() {
  local repo_root="$1"
  local json_file

  json_file="$(mktemp)"
  check_command "${repo_root}" --json > "${json_file}" 2> /dev/null || true
  python3 - "${json_file}" << 'PY'
import json
from pathlib import Path
import sys

try:
    payload = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
except (OSError, json.JSONDecodeError):
    raise SystemExit(0)

actions = [str(item).strip() for item in payload.get("next_actions", []) if str(item).strip()]
if not actions:
    raise SystemExit(0)

print("## Human Unblock")
for action in actions:
    print(f"- {action}")
print("- After completing these, rerun `mobaile ready --open-permissions --open-setup`.")
PY
  rm -f "${json_file}"
}

doctor_pairing_report() {
  local pairing_file="$1"
  local phone_access_mode="$2"
  local qr_path="$3"

  python3 - "${pairing_file}" "${phone_access_mode}" "${qr_path}" << 'PY'
import ipaddress
import json
from datetime import datetime, timezone
from pathlib import Path
import sys
from urllib.parse import urlparse

pairing_path = Path(sys.argv[1])
phone_access_mode = sys.argv[2].strip().lower() or "tailscale"
qr_path = Path(sys.argv[3])
failures = 0


def line(status: str, message: str) -> None:
    print(f"[{status}] {message}")


def fail(message: str) -> None:
    global failures
    failures += 1
    line("fail", message)


def warn(message: str) -> None:
    line("warn", message)


def ok(message: str) -> None:
    line("ok", message)


def normalize_url(raw: object) -> str:
    candidate = str(raw or "").strip().rstrip("/")
    if not candidate:
        return ""
    parsed = urlparse(candidate)
    if parsed.scheme not in {"http", "https"} or not parsed.hostname:
        return ""
    netloc = parsed.hostname.lower()
    if parsed.port is not None:
        netloc = f"{netloc}:{parsed.port}"
    return f"{parsed.scheme.lower()}://{netloc}"


def dedupe(urls: list[str]) -> list[str]:
    seen: set[str] = set()
    ordered: list[str] = []
    for raw in urls:
        normalized = normalize_url(raw)
        if not normalized or normalized in seen:
            continue
        seen.add(normalized)
        ordered.append(normalized)
    return ordered


def host_for(url: str) -> str:
    return (urlparse(url).hostname or "").lower()


def ip_address(host: str):
    try:
        return ipaddress.ip_address(host)
    except ValueError:
        return None


def is_loopback(host: str) -> bool:
    addr = ip_address(host)
    return host in {"localhost", "::1"} or bool(addr and addr.is_loopback)


def is_lan(host: str) -> bool:
    addr = ip_address(host)
    return host.endswith(".local") or bool(addr and addr.is_private and not addr.is_loopback)


def is_tailscale(host: str) -> bool:
    addr = ip_address(host)
    return host.endswith(".ts.net") or bool(
        addr
        and addr.version == 4
        and addr in ipaddress.ip_network("100.64.0.0/10")
    )


def is_public_https(url: str) -> bool:
    parsed = urlparse(url)
    host = (parsed.hostname or "").lower()
    addr = ip_address(host)
    return (
        parsed.scheme == "https"
        and not host.endswith(".local")
        and not host.endswith(".ts.net")
        and not is_loopback(host)
        and not is_tailscale(host)
        and not (addr and addr.is_private)
    )


def is_ios_permitted_tailscale_pairing_url(url: str) -> bool:
    parsed = urlparse(url)
    host = (parsed.hostname or "").lower()
    return is_public_https(url) or host.endswith(".ts.net") or parsed.scheme == "https"


if not pairing_path.exists():
    fail(f"Pairing file is missing: {pairing_path}")
    raise SystemExit(1)

try:
    payload = json.loads(pairing_path.read_text(encoding="utf-8"))
except (OSError, json.JSONDecodeError) as exc:
    fail(f"Pairing file is not readable JSON: {exc}")
    raise SystemExit(1)

server_url = normalize_url(payload.get("server_url"))
raw_urls = payload.get("server_urls")
server_urls = dedupe(raw_urls if isinstance(raw_urls, list) else [server_url])
if server_url and server_url not in server_urls:
    server_urls.insert(0, server_url)

if server_url:
    ok(f"Primary URL: {server_url}")
else:
    fail("Pairing file has no valid server_url")

if server_urls:
    ok(f"Advertised URLs: {', '.join(server_urls)}")
else:
    fail("Pairing file has no valid advertised URLs")

pair_code = str(payload.get("pair_code", "")).strip()
expires_at = str(payload.get("pair_code_expires_at", "")).strip()
if not pair_code:
    fail("Pair code is missing; run mobaile pair")
elif not expires_at:
    fail("Pair code expiry is missing; run mobaile pair")
else:
    try:
        expires = datetime.fromisoformat(expires_at.replace("Z", "+00:00"))
    except ValueError:
        fail(f"Pair code expiry is invalid: {expires_at}")
    else:
        if expires <= datetime.now(timezone.utc):
            fail("Pair code is expired; run mobaile pair")
        else:
            ok(f"Pair code is valid until {expires_at}")

if qr_path.exists():
    ok(f"Pairing QR image exists: {qr_path}")
else:
    fail(f"Pairing QR image is missing: {qr_path}")

hosts = [host_for(url) for url in server_urls]
if phone_access_mode == "tailscale":
    bad_urls = [
        url for url in server_urls
        if not (is_tailscale(host_for(url)) or is_public_https(url))
    ]
    ios_pairing_urls = [
        url for url in server_urls
        if is_ios_permitted_tailscale_pairing_url(url)
    ]
    if bad_urls:
        fail("Tailscale mode advertises Wi-Fi/local-only URL(s): " + ", ".join(bad_urls))
    elif not ios_pairing_urls:
        fail("Tailscale mode has no iOS-permitted pairing URL; use MagicDNS *.ts.net or public HTTPS")
    elif not is_ios_permitted_tailscale_pairing_url(server_urls[0]):
        fail("Primary Tailscale pairing URL may be blocked by iOS ATS: " + server_urls[0])
    elif any(is_tailscale(host) for host in hosts):
        ok("Tailscale mode advertises a Tailscale phone path")
    elif any(is_public_https(url) for url in server_urls):
        ok("Tailscale mode advertises a public HTTPS phone path")
    else:
        fail("Tailscale mode has no Tailscale or public HTTPS URL")
elif phone_access_mode == "wifi":
    if any(is_lan(host) and not is_tailscale(host) for host in hosts):
        ok("Wi-Fi mode advertises a LAN phone path")
    else:
        fail("Wi-Fi mode has no LAN URL")
elif phone_access_mode == "local":
    if all(is_loopback(host) for host in hosts):
        ok("Local mode is loopback-only")
    else:
        fail("Local mode advertises non-loopback URL(s): " + ", ".join(server_urls))
else:
    warn(f"Unknown phone access mode: {phone_access_mode}")

raise SystemExit(1 if failures else 0)
PY
}

doctor_urls() {
  local pairing_file="$1"

  python3 - "${pairing_file}" << 'PY'
import json
from pathlib import Path
import sys
from urllib.parse import urlparse

pairing_path = Path(sys.argv[1])
if not pairing_path.exists():
    raise SystemExit(0)
try:
    payload = json.loads(pairing_path.read_text(encoding="utf-8"))
except (OSError, json.JSONDecodeError):
    raise SystemExit(0)

urls = payload.get("server_urls")
if not isinstance(urls, list):
    urls = [payload.get("server_url", "")]
seen = set()
for raw in urls:
    value = str(raw or "").strip().rstrip("/")
    parsed = urlparse(value)
    if parsed.scheme not in {"http", "https"} or not parsed.hostname or value in seen:
        continue
    seen.add(value)
    print(value)
PY
}

doctor_health_check() {
  local pairing_file="$1"
  local failures=0
  local successes=0
  local urls=()
  local url code

  if [[ "${MOBAILE_DOCTOR_SKIP_NETWORK:-0}" == "1" ]]; then
    echo "[warn] Network health checks skipped by MOBAILE_DOCTOR_SKIP_NETWORK=1"
    return 0
  fi
  if ! command -v curl > /dev/null 2>&1; then
    echo "[fail] curl is required for network health checks"
    return 1
  fi

  while IFS= read -r url; do
    [[ -n "${url}" ]] && urls+=("${url}")
  done < <(doctor_urls "${pairing_file}")

  if [[ "${#urls[@]}" -eq 0 ]]; then
    echo "[fail] No advertised URLs available for health checks"
    return 1
  fi

  for url in "${urls[@]}"; do
    code="$(curl -sS --connect-timeout 3 --max-time 5 -o /dev/null -w "%{http_code}" "${url}/health" 2> /dev/null || true)"
    if [[ "${code}" == "200" ]]; then
      echo "[ok] ${url}/health returned 200"
      successes=$((successes + 1))
    else
      echo "[warn] ${url}/health returned ${code:-no response}"
      failures=$((failures + 1))
    fi
  done

  if [[ "${successes}" -eq 0 ]]; then
    echo "[fail] None of the advertised URLs answered /health"
    return 1
  fi
  return 0
}

doctor_backend_config_check() {
  local pairing_file="$1"
  local env_file="$2"
  local api_token urls=() url code body_file successes=0 failures=0

  if [[ "${MOBAILE_DOCTOR_SKIP_NETWORK:-0}" == "1" ]]; then
    echo "[warn] Backend executor config check skipped by MOBAILE_DOCTOR_SKIP_NETWORK=1"
    return 0
  fi
  if ! command -v curl > /dev/null 2>&1; then
    echo "[warn] Backend executor config check skipped because curl is unavailable"
    return 0
  fi

  api_token="$(read_env_value "${env_file}" "VOICE_AGENT_API_TOKEN" "")"
  if [[ -z "${api_token}" ]]; then
    echo "[warn] Backend executor config check skipped because VOICE_AGENT_API_TOKEN is missing"
    return 0
  fi

  while IFS= read -r url; do
    [[ -n "${url}" ]] && urls+=("${url}")
  done < <(doctor_urls "${pairing_file}")

  if [[ "${#urls[@]}" -eq 0 ]]; then
    echo "[warn] Backend executor config check skipped because no advertised URLs are available"
    return 0
  fi

  body_file="$(mktemp)"

  for url in "${urls[@]}"; do
    code="$(curl -sS --connect-timeout 3 --max-time 5 -H "Authorization: Bearer ${api_token}" -o "${body_file}" -w "%{http_code}" "${url}/v1/config" 2> /dev/null || true)"
    if [[ "${code}" != "200" ]]; then
      continue
    fi

    if python3 - "${url}" "${body_file}" << 'PY'; then
import json
from pathlib import Path
import sys

url = sys.argv[1]
body_path = Path(sys.argv[2])

try:
    payload = json.loads(body_path.read_text(encoding="utf-8"))
except (OSError, json.JSONDecodeError) as exc:
    print(f"[warn] {url}/v1/config returned unreadable JSON: {exc}")
    raise SystemExit(2)

default_executor = str(payload.get("default_executor", "")).strip().lower()
available = {
    str(value).strip().lower()
    for value in payload.get("available_executors", [])
    if str(value).strip()
}
codex_descriptor_available = False
for descriptor in payload.get("executors", []):
    if not isinstance(descriptor, dict):
        continue
    if str(descriptor.get("id", "")).strip().lower() == "codex":
        codex_descriptor_available = bool(descriptor.get("available", False))
        break

codex_ready = "codex" in available or codex_descriptor_available
if codex_ready and default_executor == "codex":
    print(f"[ok] Backend reports Codex executor ready: {url}/v1/config")
    raise SystemExit(0)
if codex_ready:
    print(f"[warn] Backend reports Codex available, but default executor is {default_executor or 'unknown'}")
    raise SystemExit(0)

print(f"[fail] Backend does not report Codex as available: {url}/v1/config")
raise SystemExit(1)
PY
      successes=$((successes + 1))
      break
    else
      failures=$((failures + 1))
    fi
  done

  if [[ "${successes}" -gt 0 ]]; then
    rm -f "${body_file}"
    return 0
  fi
  if [[ "${failures}" -gt 0 ]]; then
    rm -f "${body_file}"
    return 1
  fi

  rm -f "${body_file}"
  echo "[warn] Backend executor config check could not reach /v1/config"
  return 0
}

doctor_runtime_env_check() {
  local repo_root="$1"
  local active_backend="$2"
  local checkout_env="${repo_root}/backend/.env"
  local active_env="${active_backend}/.env"
  local drift_output

  if [[ "$(same_path "${checkout_env}" "${active_env}")" == "yes" ]]; then
    echo "[ok] Active backend is using the checkout env file"
    return 0
  fi

  if drift_output="$(runtime_env_drift_messages "${checkout_env}" "${active_env}")"; then
    echo "[ok] Active runtime env matches checkout access config"
    return 0
  fi

  printf "%s\n" "${drift_output}"
  return 1
}

doctor_keep_awake_check() {
  local repo_root="$1"
  local state

  state="$(keep_awake_state_label "${repo_root}")"
  case "${state}" in
    Running)
      echo "[ok] Keep-awake service is running"
      ;;
    Unsupported)
      echo "[warn] Keep-awake service is macOS-only"
      ;;
    *)
      echo "[warn] Keep-awake service is not running; run mobaile awake"
      ;;
  esac
  return 0
}

doctor_command() {
  local repo_root="$1"
  local backend_dir env_file pairing_file qr_path phone_access_mode state failures=0

  backend_dir="$(active_backend_dir "${repo_root}")"
  env_file="${backend_dir}/.env"
  pairing_file="${backend_dir}/pairing.json"
  qr_path="$(pairing_qr_path "${backend_dir}")"
  phone_access_mode="$(read_env_value "${env_file}" "VOICE_AGENT_PHONE_ACCESS_MODE" "tailscale")"
  state="$(service_state_label "${repo_root}")"

  echo "MOBaiLE doctor"
  echo "Active backend: ${backend_dir}"
  echo "Phone access mode: $(friendly_phone_access_label "${phone_access_mode}" "$(read_env_value "${env_file}" "VOICE_AGENT_PUBLIC_SERVER_URL" "")" "$(read_pairing_value "${pairing_file}" "server_url" "")") (${phone_access_mode})"

  if [[ "${state}" == "Running" ]]; then
    echo "[ok] Backend service is running"
  else
    echo "[fail] Backend service is not running"
    failures=$((failures + 1))
  fi

  if ! doctor_pairing_report "${pairing_file}" "${phone_access_mode}" "${qr_path}"; then
    failures=$((failures + 1))
  fi

  if ! doctor_health_check "${pairing_file}"; then
    failures=$((failures + 1))
  fi

  if ! doctor_codex_binary_check "${env_file}"; then
    failures=$((failures + 1))
  fi

  if ! doctor_backend_config_check "${pairing_file}" "${env_file}"; then
    failures=$((failures + 1))
  fi

  if ! doctor_runtime_env_check "${repo_root}" "${backend_dir}"; then
    failures=$((failures + 1))
  fi

  doctor_keep_awake_check "${repo_root}"

  if [[ "${failures}" -eq 0 ]]; then
    echo "Doctor result: ready"
    return 0
  fi
  echo "Doctor result: attention needed"
  return 1
}

json_file_field() {
  local json_file="$1"
  local field_name="$2"
  local default_value="${3:-}"

  python3 - "${json_file}" "${field_name}" "${default_value}" << 'PY'
import json
from pathlib import Path
import sys

path = Path(sys.argv[1])
field = sys.argv[2]
default = sys.argv[3]

try:
    payload = json.loads(path.read_text(encoding="utf-8"))
except (OSError, json.JSONDecodeError):
    print(default)
    raise SystemExit(0)

value = payload.get(field, default)
if value is None:
    value = default
print(str(value))
PY
}

first_run_usage() {
  cat << 'EOF'
Usage: mobaile first-run [options]

Options:
  --executor <shell|codex|claude>  Force the starter run executor
  --workdir <path>                 Use a custom playground directory
  --timeout <seconds>              Wait time before giving up (default: 120)
EOF
}

first_run_normalize_executor() {
  local executor="$1"
  executor="$(printf "%s" "${executor}" | tr '[:upper:]' '[:lower:]')"
  if [[ "${executor}" == "local" ]]; then
    executor="shell"
  fi
  printf "%s\n" "${executor}"
}

first_run_choose_executor() {
  local env_file="$1"
  local requested="$2"
  local default_executor codex_binary claude_binary

  if [[ -n "${requested}" ]]; then
    first_run_normalize_executor "${requested}"
    return
  fi

  default_executor="$(first_run_normalize_executor "$(read_env_value "${env_file}" "VOICE_AGENT_DEFAULT_EXECUTOR" "codex")")"
  codex_binary="$(read_env_value "${env_file}" "VOICE_AGENT_CODEX_BINARY" "codex")"
  claude_binary="$(read_env_value "${env_file}" "VOICE_AGENT_CLAUDE_BINARY" "claude")"

  case "${default_executor}" in
    shell)
      printf "shell\n"
      return
      ;;
    codex)
      if resolve_executable_path "${codex_binary}" > /dev/null 2>&1; then
        printf "codex\n"
        return
      fi
      ;;
    claude)
      if resolve_executable_path "${claude_binary}" > /dev/null 2>&1; then
        printf "claude\n"
        return
      fi
      ;;
  esac

  if resolve_executable_path "${codex_binary}" > /dev/null 2>&1; then
    printf "codex\n"
    return
  fi
  if resolve_executable_path "${claude_binary}" > /dev/null 2>&1; then
    printf "claude\n"
    return
  fi
  printf "shell\n"
}

first_run_validate_executor() {
  local env_file="$1"
  local executor="$2"
  local binary
  executor="$(first_run_normalize_executor "${executor}")"

  case "${executor}" in
    shell)
      return 0
      ;;
    codex)
      binary="$(read_env_value "${env_file}" "VOICE_AGENT_CODEX_BINARY" "codex")"
      if resolve_executable_path "${binary}" > /dev/null 2>&1; then
        return 0
      fi
      echo "Codex CLI is not available to this shell: ${binary}" >&2
      return 1
      ;;
    claude)
      binary="$(read_env_value "${env_file}" "VOICE_AGENT_CLAUDE_BINARY" "claude")"
      if resolve_executable_path "${binary}" > /dev/null 2>&1; then
        return 0
      fi
      echo "Claude CLI is not available to this shell: ${binary}" >&2
      return 1
      ;;
    *)
      echo "Invalid executor: ${executor}. Expected shell, codex, or claude." >&2
      return 1
      ;;
  esac
}

first_run_default_prompt() {
  local executor="$1"
  case "${executor}" in
    shell)
      printf "%s\n" "printf \"print('hello from voice agent')\\n\" > hello.py && python3 hello.py"
      ;;
    *)
      printf "%s\n" "create a hello python script and run it"
      ;;
  esac
}

cleanup_first_run_response_file() {
  if [[ -n "${MOBAILE_FIRST_RUN_RESPONSE_FILE:-}" ]]; then
    rm -f "${MOBAILE_FIRST_RUN_RESPONSE_FILE}"
  fi
}

first_run_request_body() {
  local executor="$1"
  local workdir="$2"
  local prompt="$3"

  FIRST_RUN_EXECUTOR="${executor}" \
    FIRST_RUN_WORKDIR="${workdir}" \
    FIRST_RUN_PROMPT="${prompt}" \
    python3 - << 'PY'
import json
import os

print(json.dumps({
    "session_id": "mobaile-first-run",
    "thread_id": "mobaile-first-run",
    "utterance_text": os.environ["FIRST_RUN_PROMPT"],
    "executor": os.environ["FIRST_RUN_EXECUTOR"],
    "working_directory": os.environ["FIRST_RUN_WORKDIR"],
    "response_mode": "concise",
    "response_profile": "guided",
}))
PY
}

first_run_command() {
  local repo_root="$1"
  shift || true
  local requested_executor="" timeout_sec="${MOBAILE_FIRST_RUN_TIMEOUT:-120}"
  local workdir="${MOBAILE_FIRST_RUN_WORKDIR:-${HOME}/MOBaiLE-playground}"
  local backend_dir env_file pairing_file server_url token executor prompt response_file code run_id status summary deadline request_body

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --executor)
        if [[ $# -lt 2 ]]; then
          echo "--executor requires a value." >&2
          return 1
        fi
        requested_executor="$2"
        shift 2
        ;;
      --workdir)
        if [[ $# -lt 2 ]]; then
          echo "--workdir requires a value." >&2
          return 1
        fi
        workdir="$2"
        shift 2
        ;;
      --timeout)
        if [[ $# -lt 2 ]]; then
          echo "--timeout requires a value." >&2
          return 1
        fi
        timeout_sec="$2"
        shift 2
        ;;
      -h | --help)
        first_run_usage
        return 0
        ;;
      *)
        first_run_usage >&2
        echo "Unknown first-run argument: $1" >&2
        return 1
        ;;
    esac
  done

  case "${timeout_sec}" in
    '' | *[!0-9]*)
      echo "--timeout must be a positive integer." >&2
      return 1
      ;;
    0)
      echo "--timeout must be greater than zero." >&2
      return 1
      ;;
  esac

  backend_dir="$(active_backend_dir "${repo_root}")"
  env_file="${backend_dir}/.env"
  pairing_file="${backend_dir}/pairing.json"
  server_url="$(read_pairing_value "${pairing_file}" "server_url" "")"
  token="$(read_env_value "${env_file}" "VOICE_AGENT_API_TOKEN" "")"
  executor="$(first_run_choose_executor "${env_file}" "${requested_executor}")"
  prompt="${MOBAILE_FIRST_RUN_PROMPT:-$(first_run_default_prompt "${executor}")}"

  if ! command -v curl > /dev/null 2>&1; then
    echo "curl is required for mobaile first-run." >&2
    return 1
  fi
  if [[ -z "${server_url}" || -z "${token}" ]]; then
    echo "First run needs a configured backend URL and API token." >&2
    echo "Run mobaile status, then mobaile pair if pairing is not ready." >&2
    return 1
  fi
  if ! first_run_validate_executor "${env_file}" "${executor}"; then
    echo "Retry with --executor shell for the safe starter fallback." >&2
    return 1
  fi

  mkdir -p "${workdir}"
  request_body="$(first_run_request_body "${executor}" "${workdir}" "${prompt}")"
  response_file="$(mktemp)"
  MOBAILE_FIRST_RUN_RESPONSE_FILE="${response_file}"
  trap cleanup_first_run_response_file EXIT

  echo "MOBaiLE first run"
  echo "Server: ${server_url}"
  echo "Executor: ${executor}"
  echo "Playground: ${workdir}"

  code="$(
    curl -sS -o "${response_file}" -w "%{http_code}" \
      -X POST "${server_url}/v1/utterances" \
      -H "Authorization: Bearer ${token}" \
      -H 'Content-Type: application/json' \
      -d "${request_body}" || true
  )"
  if [[ "${code}" != "200" ]]; then
    echo "Could not start first run; /v1/utterances returned ${code:-no response}." >&2
    echo "Run mobaile check or mobaile repair to diagnose setup." >&2
    return 1
  fi

  run_id="$(json_file_field "${response_file}" "run_id" "")"
  if [[ -z "${run_id}" ]]; then
    echo "Could not read run_id from backend response." >&2
    return 1
  fi
  echo "Run: ${run_id}"

  deadline=$((SECONDS + timeout_sec))
  status="running"
  while [[ "${SECONDS}" -lt "${deadline}" ]]; do
    code="$(curl -sS -o "${response_file}" -w "%{http_code}" -H "Authorization: Bearer ${token}" "${server_url}/v1/runs/${run_id}" || true)"
    if [[ "${code}" != "200" ]]; then
      echo "Waiting for run status returned ${code:-no response}." >&2
      sleep 1
      continue
    fi
    status="$(json_file_field "${response_file}" "status" "running")"
    case "${status}" in
      completed | failed | cancelled | blocked)
        break
        ;;
    esac
    sleep 1
  done

  summary="$(json_file_field "${response_file}" "summary" "")"
  echo "Status: ${status}"
  if [[ -n "${summary}" ]]; then
    echo "Summary: ${summary}"
  fi

  if [[ "${status}" == "completed" ]]; then
    echo "First run complete. MOBaiLE can start work from your phone."
    return 0
  fi
  echo "First run did not complete. Run mobaile doctor for details." >&2
  return 1
}

demo_usage() {
  cat << 'EOF'
Usage: mobaile demo [options]

Options:
  --sample                       Export the built-in sanitized sample replay (default)
  --run-id <id>                  Export a sanitized replay from an existing backend run
  --format <markdown|json>       Output format (default: markdown)
  --out <path|->                 Output path, or - for stdout
  --events-limit <count>         Max events to fetch for --run-id (default: 100)
EOF
}

cleanup_demo_response_file() {
  if [[ -n "${MOBAILE_DEMO_RESPONSE_FILE:-}" ]]; then
    rm -f "${MOBAILE_DEMO_RESPONSE_FILE}"
  fi
}

demo_sample_run_json() {
  python3 - << 'PY'
import json

print(json.dumps({
    "run_id": "demo-local-agent-from-phone",
    "status": "completed",
    "executor": "codex",
    "summary": "Created a small hello script, ran it, and returned the result to the phone.",
    "events": [
        {
            "seq": 0,
            "type": "activity.started",
            "stage": "planning",
            "display_message": "Planning a safe starter task.",
            "message": "Planning a safe starter task.",
        },
        {
            "seq": 1,
            "type": "activity.updated",
            "stage": "executing",
            "display_message": "Creating and running the script on the paired host.",
            "message": "Creating and running the script on the paired host.",
        },
        {
            "seq": 2,
            "type": "activity.completed",
            "stage": "summarizing",
            "display_message": "Summarizing the result for the phone thread.",
            "message": "Summarizing the result for the phone thread.",
        },
        {
            "seq": 3,
            "type": "chat.message",
            "message": json.dumps({
                "type": "assistant_response",
                "version": "1.0",
                "summary": "The hello script ran successfully on the host.",
                "sections": [],
                "agenda_items": [],
            }),
        },
        {
            "seq": 4,
            "type": "run.completed",
            "stage": "summarizing",
            "message": "Run completed successfully.",
        },
    ],
}))
PY
}

demo_render_file() {
  local run_file="$1"
  local output_format="$2"
  local source_label="$3"

  python3 - "${run_file}" "${output_format}" "${source_label}" << 'PY'
from __future__ import annotations

from datetime import datetime, timezone
import json
from pathlib import Path
import re
import sys
from typing import Any

run_path = Path(sys.argv[1])
output_format = sys.argv[2]
source_label = sys.argv[3]

try:
    raw_run = json.loads(run_path.read_text(encoding="utf-8"))
except (OSError, json.JSONDecodeError) as exc:
    print(f"Could not read run JSON: {exc}", file=sys.stderr)
    raise SystemExit(1)


def text(value: object, *, limit: int = 220) -> str:
    cleaned = re.sub(r"\s+", " ", str(value or "")).strip()
    if len(cleaned) <= limit:
        return cleaned
    return cleaned[: limit - 1].rstrip() + "..."


def stage_label(raw_stage: object, event_type: str) -> str:
    stage = text(raw_stage, limit=40).lower()
    if stage:
        return stage
    if event_type == "run.completed":
        return "summarizing"
    if event_type == "run.blocked":
        return "blocked"
    if event_type in {"run.failed", "run.cancelled"}:
        return "blocked"
    return "executing"


def message_for_event(event: dict[str, Any]) -> str:
    return text(
        event.get("display_message")
        or event.get("title")
        or event.get("message")
        or event.get("type")
    )


def chat_summary(event: dict[str, Any]) -> str:
    raw = event.get("message")
    if not isinstance(raw, str):
        return ""
    try:
        payload = json.loads(raw)
    except json.JSONDecodeError:
        return ""
    if isinstance(payload, dict) and payload.get("type") == "assistant_response":
        return text(payload.get("summary"))
    return ""


def sanitized_events(raw_events: list[Any]) -> list[dict[str, str]]:
    events: list[dict[str, str]] = []
    for raw in raw_events:
        if not isinstance(raw, dict):
            continue
        event_type = text(raw.get("type"), limit=60)
        if event_type.startswith("activity."):
            events.append({
                "stage": stage_label(raw.get("stage"), event_type),
                "message": message_for_event(raw),
                "type": event_type,
            })
            continue
        if event_type in {"run.completed", "run.failed", "run.blocked", "run.cancelled"}:
            events.append({
                "stage": stage_label(raw.get("stage"), event_type),
                "message": message_for_event(raw),
                "type": event_type,
            })
            continue
        summary = chat_summary(raw)
        if summary:
            events.append({
                "stage": "summarizing",
                "message": summary,
                "type": "chat.summary",
            })
    return events


events = sanitized_events(raw_run.get("events") if isinstance(raw_run.get("events"), list) else [])
summary = text(raw_run.get("summary"), limit=260)
payload = {
    "type": "mobaile_demo_replay",
    "version": "1.0",
    "generated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
    "source": source_label,
    "run_id": text(raw_run.get("run_id"), limit=100),
    "status": text(raw_run.get("status"), limit=40),
    "executor": text(raw_run.get("executor"), limit=40),
    "summary": summary,
    "events": events,
    "trust_notes": [
        "The iPhone is the control surface; code runs on the paired Mac or Linux host.",
        "The replay omits raw logs, stdout, stderr, prompts, file paths, and tokens by default.",
        "Pairing uses a QR and one-time pair code; the long-lived API token stays host-side.",
    ],
}

if output_format == "json":
    print(json.dumps(payload, indent=2))
    raise SystemExit(0)

install_command = "curl -fsSL https://raw.githubusercontent.com/Vemundss/mobaile/main/scripts/install.sh | bash -s -- --yes"
print("# MOBaiLE Demo Replay")
print()
print("MOBaiLE turns an iPhone into a control surface for a Mac or Linux machine you already trust.")
print("The host keeps the repo, shell, credentials, files, and network access; the phone starts and follows the run.")
print()
print("## Demo Source")
print()
print(f"- Source: {payload['source']}")
print(f"- Run: `{payload['run_id'] or 'sample'}`")
print(f"- Executor: `{payload['executor'] or 'unknown'}`")
print(f"- Status: `{payload['status'] or 'unknown'}`")
if summary:
    print(f"- Summary: {summary}")
print()
print("## Sanitized Run Flow")
print()
print("| Stage | What the phone can show |")
print("| --- | --- |")
if events:
    for event in events:
        print(f"| {event['stage']} | {event['message']} |")
else:
    print("| summarizing | No phone-safe activity events were available in this run export. |")
print()
print("## Why It Matters")
print()
print("- Start work from the phone without moving private repo context into a hosted workspace.")
print("- Follow planning, execution, blocked states, and final results in one live thread.")
print("- Share a proof artifact without exposing raw logs, commands, file paths, or tokens.")
print()
print("## Try It")
print()
print("```bash")
print(install_command)
print("mobaile first-run")
print("mobaile demo --out mobaile-demo.md")
print("```")
PY
}

demo_command() {
  local repo_root="$1"
  shift || true
  local run_id="" output_format="markdown" out_path="" events_limit="100" use_sample="true"
  local backend_dir env_file pairing_file server_url token response_file code render_file extension

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --sample)
        use_sample="true"
        shift
        ;;
      --run-id)
        if [[ $# -lt 2 ]]; then
          echo "--run-id requires a value." >&2
          return 1
        fi
        run_id="$2"
        use_sample="false"
        shift 2
        ;;
      --format)
        if [[ $# -lt 2 ]]; then
          echo "--format requires a value." >&2
          return 1
        fi
        output_format="$2"
        shift 2
        ;;
      --out)
        if [[ $# -lt 2 ]]; then
          echo "--out requires a value." >&2
          return 1
        fi
        out_path="$2"
        shift 2
        ;;
      --events-limit)
        if [[ $# -lt 2 ]]; then
          echo "--events-limit requires a value." >&2
          return 1
        fi
        events_limit="$2"
        shift 2
        ;;
      -h | --help)
        demo_usage
        return 0
        ;;
      *)
        demo_usage >&2
        echo "Unknown demo argument: $1" >&2
        return 1
        ;;
    esac
  done

  case "${output_format}" in
    markdown | json) ;;
    *)
      echo "--format must be markdown or json." >&2
      return 1
      ;;
  esac
  case "${events_limit}" in
    '' | *[!0-9]*)
      echo "--events-limit must be a non-negative integer." >&2
      return 1
      ;;
  esac
  if [[ "${events_limit}" -gt 500 ]]; then
    echo "--events-limit must be 500 or lower." >&2
    return 1
  fi

  response_file="$(mktemp)"
  MOBAILE_DEMO_RESPONSE_FILE="${response_file}"
  trap cleanup_demo_response_file EXIT

  if [[ "${use_sample}" == "true" ]]; then
    demo_sample_run_json > "${response_file}"
    render_file="${response_file}"
  else
    if ! command -v curl > /dev/null 2>&1; then
      echo "curl is required for mobaile demo --run-id." >&2
      return 1
    fi
    backend_dir="$(active_backend_dir "${repo_root}")"
    env_file="${backend_dir}/.env"
    pairing_file="${backend_dir}/pairing.json"
    server_url="$(read_pairing_value "${pairing_file}" "server_url" "")"
    token="$(read_env_value "${env_file}" "VOICE_AGENT_API_TOKEN" "")"
    if [[ -z "${server_url}" || -z "${token}" ]]; then
      echo "Run export needs a configured backend URL and API token." >&2
      echo "Run mobaile status, then mobaile pair if pairing is not ready." >&2
      return 1
    fi
    code="$(
      curl -sS -o "${response_file}" -w "%{http_code}" \
        -H "Authorization: Bearer ${token}" \
        "${server_url}/v1/runs/${run_id}?events_limit=${events_limit}" || true
    )"
    if [[ "${code}" != "200" ]]; then
      echo "Could not export run; /v1/runs/${run_id} returned ${code:-no response}." >&2
      return 1
    fi
    render_file="${response_file}"
  fi

  if [[ -z "${out_path}" ]]; then
    extension="md"
    if [[ "${output_format}" == "json" ]]; then
      extension="json"
    fi
    out_path="mobaile-demo.${extension}"
  fi

  if [[ "${out_path}" == "-" ]]; then
    demo_render_file "${render_file}" "${output_format}" "$([[ "${use_sample}" == "true" ]] && printf "built-in sample" || printf "backend run")"
    return
  fi

  mkdir -p "$(dirname "${out_path}")"
  demo_render_file "${render_file}" "${output_format}" "$([[ "${use_sample}" == "true" ]] && printf "built-in sample" || printf "backend run")" > "${out_path}"
  echo "MOBaiLE demo exported: ${out_path}"
}

pair_command() {
  local repo_root="$1"
  local backend_dir
  local pairing_file
  local qr_path

  backend_dir="$(active_backend_dir "${repo_root}")"
  pairing_file="${backend_dir}/pairing.json"
  qr_path="$(pairing_qr_path "${backend_dir}")"

  if [[ -n "${MOBAILE_TEST_PAIRING_QR:-}" ]]; then
    mkdir -p "$(dirname "${qr_path}")"
    : > "${qr_path}"
  else
    if [[ ! -f "${pairing_file}" ]]; then
      echo "Pairing is not ready. Missing ${pairing_file}." >&2
      echo "Run mobaile status after the backend is configured." >&2
      return 1
    fi

    if [[ ! -f "${repo_root}/scripts/pairing_qr.sh" ]]; then
      echo "Missing pairing QR helper: ${repo_root}/scripts/pairing_qr.sh" >&2
      return 1
    fi

    MOBAILE_BACKEND_DIR="${backend_dir}" \
      MOBAILE_PAIRING_FILE="${pairing_file}" \
      MOBAILE_PAIRING_QR_OUT="${qr_path}" \
      MOBAILE_QR_PYTHON_ENV_DIR="${backend_dir}" \
      MOBAILE_PAIR_FORCE_REFRESH=1 \
      bash "${repo_root}/scripts/pairing_qr.sh" --out "${qr_path}" --quiet --no-preview
  fi

  cat << EOF
Pairing QR: ${qr_path}
URL: $(read_pairing_value "${pairing_file}" "server_url" "Not ready")
Phone pairing: $(pairing_status_label "${pairing_file}")
EOF

  if [[ -f "${qr_path}" ]]; then
    open_file_if_possible "${qr_path}"
  else
    echo "QR image is not available yet at ${qr_path}."
  fi
}

repair_command() {
  local repo_root="$1"
  local service_script
  local failures=0

  echo "MOBaiLE repair"

  if [[ "$(service_install_preference)" == "yes" ]]; then
    service_script="$(service_script_path "${repo_root}")"
    if [[ -f "${service_script}" ]]; then
      echo "Restarting backend service..."
      if ! bash "${service_script}" restart; then
        echo "Backend restart reported a problem." >&2
        failures=$((failures + 1))
      fi
    else
      echo "Service helper is missing: ${service_script}" >&2
      failures=$((failures + 1))
    fi
  else
    echo "Background service is not installed; skipping restart."
  fi

  echo
  echo "Refreshing pairing QR..."
  if ! pair_command "${repo_root}"; then
    failures=$((failures + 1))
  fi

  echo
  if ! doctor_command "${repo_root}"; then
    failures=$((failures + 1))
  fi

  if [[ "${failures}" -eq 0 ]]; then
    echo "Repair result: ready"
    return 0
  fi
  echo "Repair result: attention needed"
  return 1
}

uninstall_usage() {
  cat << 'EOF'
Usage: mobaile uninstall [options]

Options:
  --keep-data       Stop services and remove the mobaile command, but keep local data (default)
  --delete-data     Delete MOBaiLE runtime data, logs, pairing state, and checkout-local backend state
  --delete-checkout Delete the current MOBaiLE checkout after other uninstall work
  --remove-codex-mcp
                    Remove Codex MCP entries named peekaboo and playwright
  --yes             Skip confirmation for destructive options
  --dry-run         Print what would be changed without changing anything
EOF
}

uninstall_confirm() {
  local delete_data="$1"
  local delete_checkout="$2"
  local remove_codex_mcp="$3"

  if [[ "${delete_data}" != "true" && "${delete_checkout}" != "true" && "${remove_codex_mcp}" != "true" ]]; then
    return 0
  fi
  if [[ ! -t 0 ]]; then
    echo "Destructive uninstall options require --yes when running non-interactively." >&2
    return 1
  fi

  local confirmation
  echo "This will delete selected MOBaiLE files on this computer."
  read -r -p "Continue? Type 'uninstall' to confirm: " confirmation
  if [[ "${confirmation}" != "uninstall" ]]; then
    echo "Uninstall cancelled."
    return 1
  fi
}

uninstall_run() {
  local dry_run="$1"
  shift

  if [[ "${dry_run}" == "true" ]]; then
    echo "Would run: $(format_command "$@")"
    return 0
  fi

  "$@"
}

uninstall_delete_path() {
  local dry_run="$1"
  local path="$2"
  local label="$3"

  if [[ -z "${path}" || "${path}" == "/" || "${path}" == "${HOME}" ]]; then
    echo "Refusing to delete unsafe ${label} path: ${path:-<empty>}" >&2
    return 1
  fi

  if [[ ! -e "${path}" && ! -L "${path}" ]]; then
    echo "${label}: already absent"
    return 0
  fi

  if [[ "${dry_run}" == "true" ]]; then
    echo "Would delete ${label}: ${path}"
    return 0
  fi

  rm -rf "${path}"
  echo "Deleted ${label}: ${path}"
}

uninstall_remove_command() {
  local repo_root="$1"
  local dry_run="$2"
  local command_path="${HOME}/.local/bin/mobaile"
  local expected_target="${repo_root}/scripts/mobaile"
  local actual_target=""

  if [[ ! -e "${command_path}" && ! -L "${command_path}" ]]; then
    echo "mobaile command: already absent"
    return 0
  fi
  if [[ ! -L "${command_path}" ]]; then
    echo "Leaving ${command_path}; it is not a MOBaiLE symlink."
    return 0
  fi

  actual_target="$(readlink "${command_path}")"
  if [[ "${actual_target}" != "${expected_target}" ]]; then
    echo "Leaving ${command_path}; it points to ${actual_target}, not ${expected_target}."
    return 0
  fi

  uninstall_delete_path "${dry_run}" "${command_path}" "mobaile command"
}

uninstall_delete_checkout_state() {
  local repo_root="$1"
  local dry_run="$2"
  local backend_dir="${repo_root}/backend"
  local state_path

  for state_path in \
    "${backend_dir}/.env" \
    "${backend_dir}/pairing.json" \
    "${backend_dir}/pairing-qr.png" \
    "${backend_dir}/data" \
    "${backend_dir}/logs" \
    "${backend_dir}/sandbox" \
    "${backend_dir}/.mobaile"; do
    uninstall_delete_path "${dry_run}" "${state_path}" "checkout state"
  done
}

uninstall_remove_codex_mcp() {
  local repo_root="$1"
  local dry_run="$2"
  local backend_dir env_file codex_home_raw codex_home name

  if ! command -v codex > /dev/null 2>&1; then
    echo "Codex MCP cleanup skipped; codex is not available."
    return 0
  fi

  backend_dir="$(active_backend_dir "${repo_root}")"
  env_file="${backend_dir}/.env"
  codex_home_raw="$(read_env_value "${env_file}" "VOICE_AGENT_CODEX_HOME" "${HOME}/.codex")"
  codex_home="$(resolve_backend_path "${backend_dir}" "${codex_home_raw}" "${HOME}/.codex")"

  for name in peekaboo playwright; do
    if [[ "${dry_run}" == "true" ]]; then
      echo "Would run: CODEX_HOME=${codex_home} codex mcp remove ${name}"
      continue
    fi
    if CODEX_HOME="${codex_home}" codex mcp remove "${name}" > /dev/null 2>&1; then
      echo "Removed Codex MCP entry: ${name}"
    else
      echo "Codex MCP entry absent or unchanged: ${name}"
    fi
  done
}

uninstall_command() {
  local repo_root="$1"
  shift || true
  local delete_data="false"
  local delete_checkout="false"
  local remove_codex_mcp="false"
  local assume_yes="false"
  local dry_run="false"
  local service_script runtime_root

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --keep-data)
        delete_data="false"
        shift
        ;;
      --delete-data)
        delete_data="true"
        shift
        ;;
      --delete-checkout)
        delete_checkout="true"
        shift
        ;;
      --remove-codex-mcp)
        remove_codex_mcp="true"
        shift
        ;;
      --yes | --non-interactive)
        assume_yes="true"
        shift
        ;;
      --dry-run)
        dry_run="true"
        shift
        ;;
      -h | --help)
        uninstall_usage
        return 0
        ;;
      *)
        uninstall_usage >&2
        echo "Unknown uninstall argument: $1" >&2
        return 1
        ;;
    esac
  done

  if [[ "${assume_yes}" != "true" && "${dry_run}" != "true" ]]; then
    uninstall_confirm "${delete_data}" "${delete_checkout}" "${remove_codex_mcp}" || return 1
  fi

  echo "MOBaiLE uninstall"

  service_script="$(service_script_path "${repo_root}")"
  if [[ -f "${service_script}" ]]; then
    if [[ "$(service_install_preference)" == "yes" ]]; then
      uninstall_run "${dry_run}" bash "${service_script}" uninstall
    else
      echo "Background service: already absent"
    fi
    if [[ "$(keep_awake_install_preference)" == "yes" ]]; then
      uninstall_run "${dry_run}" bash "${service_script}" keep-awake-uninstall
    elif [[ "$(uname -s)" == "Darwin" ]]; then
      echo "Keep-awake service: already absent"
    fi
  else
    echo "Service helper missing: ${service_script}"
  fi

  uninstall_remove_command "${repo_root}" "${dry_run}"

  if [[ "${remove_codex_mcp}" == "true" ]]; then
    uninstall_remove_codex_mcp "${repo_root}" "${dry_run}"
  fi

  if [[ "${delete_data}" == "true" ]]; then
    runtime_root="$(runtime_data_root)"
    if [[ -n "${runtime_root}" ]]; then
      uninstall_delete_path "${dry_run}" "${runtime_root}" "runtime data"
    fi
    uninstall_delete_checkout_state "${repo_root}" "${dry_run}"
  else
    echo "Data kept. Reinstall later with the existing pairing/data still present."
  fi

  if [[ "${delete_checkout}" == "true" ]]; then
    cd "${HOME}" 2> /dev/null || cd / 2> /dev/null || true
    uninstall_delete_path "${dry_run}" "${repo_root}" "checkout"
  else
    echo "Checkout kept: ${repo_root}"
  fi

  if [[ "${dry_run}" == "true" ]]; then
    echo "Dry run complete."
  else
    echo "Uninstall complete."
  fi
}

delegate_service_command() {
  local repo_root="$1"
  local command_name="$2"
  local service_script

  service_script="$(service_script_path "${repo_root}")"
  if [[ ! -f "${service_script}" ]]; then
    echo "Missing service helper: ${service_script}" >&2
    exit 1
  fi

  exec bash "${service_script}" "${command_name}"
}

config_command() {
  local repo_root="$1"
  local checkout_backend_dir="${repo_root}/backend"
  local backend_dir
  local env_file
  local checkout_env_file
  local pairing_file
  local qr_path service_script security_mode phone_access_mode public_server_url api_token server_url drift_output

  backend_dir="$(active_backend_dir "${repo_root}")"
  env_file="${backend_dir}/.env"
  checkout_env_file="${checkout_backend_dir}/.env"
  pairing_file="${backend_dir}/pairing.json"
  qr_path="$(pairing_qr_path "${backend_dir}")"
  service_script="$(service_script_path "${repo_root}")"
  security_mode="$(read_env_value "${env_file}" "VOICE_AGENT_SECURITY_MODE" "safe")"
  phone_access_mode="$(read_env_value "${env_file}" "VOICE_AGENT_PHONE_ACCESS_MODE" "tailscale")"
  public_server_url="$(read_env_value "${env_file}" "VOICE_AGENT_PUBLIC_SERVER_URL" "")"
  api_token="$(read_env_value "${env_file}" "VOICE_AGENT_API_TOKEN" "")"
  server_url="$(read_pairing_value "${pairing_file}" "server_url" "Not ready")"
  drift_output="$(runtime_env_drift_output "${repo_root}" "${backend_dir}")"

  cat << EOF
MOBaiLE configuration

Repo root: ${repo_root}
Checkout backend dir: ${checkout_backend_dir}
Active backend dir: ${backend_dir}
Checkout env file: ${checkout_env_file} $(path_presence_label "${checkout_env_file}")
Active env file: ${env_file} $(path_presence_label "${env_file}")
Pairing file: ${pairing_file} $(path_presence_label "${pairing_file}")
Pairing QR image: ${qr_path} $(path_presence_label "${qr_path}")
Service helper: ${service_script}

Security mode: $(friendly_security_label "${security_mode}") (${security_mode})
Phone access mode: $(friendly_phone_access_label "${phone_access_mode}" "${public_server_url}" "${server_url}") (${phone_access_mode})
API token: $([[ -n "${api_token}" ]] && printf "Configured" || printf "Missing")
Server URL: ${server_url}
Phone pairing: $(pairing_status_label "${pairing_file}")
EOF
  if [[ -n "${drift_output}" ]]; then
    printf "\n%s\n" "${drift_output}"
  fi
}

update_command() {
  local repo_root="$1"
  local update_mode="${2:-apply}"
  local env_file="${repo_root}/backend/.env"
  local branch remote_url local_ref remote_ref security_mode phone_access_mode public_server_url background_service

  git_checkout_or_fail "${repo_root}"
  branch="$(git_current_branch "${repo_root}")"
  remote_url="$(git_origin_url "${repo_root}")"

  if [[ -z "${remote_url}" ]]; then
    echo "Could not find an origin remote for this checkout." >&2
    exit 1
  fi
  if ! remote_is_update_source "${remote_url}"; then
    echo "Refusing to auto-update from an unrecognized remote: ${remote_url}" >&2
    exit 1
  fi

  fetch_update_refs "${repo_root}"
  local_ref="$(git_short_ref "${repo_root}" "HEAD")"
  remote_ref="$(git_short_ref "${repo_root}" "origin/main")"
  if [[ -z "${remote_ref}" ]]; then
    echo "Could not resolve origin/main for this checkout." >&2
    exit 1
  fi

  if [[ "${update_mode}" == "check" ]]; then
    print_update_status "${repo_root}" "${branch:-detached}" "${local_ref}" "${remote_ref}"
    return
  fi

  if [[ "${branch}" != "main" ]]; then
    echo "mobaile update only supports the main branch. Current branch: ${branch:-detached}." >&2
    exit 1
  fi
  if git_worktree_dirty "${repo_root}"; then
    echo "mobaile update requires a clean checkout. Commit or stash local changes first." >&2
    exit 1
  fi

  if [[ "${local_ref}" == "${remote_ref}" ]]; then
    echo "MOBaiLE is already up to date (${local_ref})."
    return
  fi

  echo "Updating MOBaiLE from ${local_ref} to ${remote_ref}..."
  git -C "${repo_root}" pull --ff-only > /dev/null

  security_mode="$(read_env_value "${env_file}" "VOICE_AGENT_SECURITY_MODE" "safe")"
  phone_access_mode="$(read_env_value "${env_file}" "VOICE_AGENT_PHONE_ACCESS_MODE" "tailscale")"
  public_server_url="$(read_env_value "${env_file}" "VOICE_AGENT_PUBLIC_SERVER_URL" "")"
  background_service="$(service_install_preference)"

  local install_args=(
    bash "${repo_root}/scripts/install.sh"
    --checkout "${repo_root}"
    --non-interactive
    --mode "${security_mode}"
    --phone-access "${phone_access_mode}"
    --background-service "${background_service}"
  )
  if [[ -n "${public_server_url}" ]]; then
    install_args+=(--public-url "${public_server_url}")
  fi

  "${install_args[@]}"
  echo "Updated MOBaiLE to $(git_short_ref "${repo_root}" "HEAD")."
}

main() {
  local repo_root command_name
  repo_root="$(resolve_repo_root)"
  command_name="${1:-status}"

  case "${command_name}" in
    status) status_command "${repo_root}" ;;
    setup)
      shift || true
      setup_command "${repo_root}" "$@"
      ;;
    autonomy)
      shift || true
      autonomy_command "${repo_root}" "$@"
      ;;
    check)
      shift || true
      check_command "${repo_root}" "$@"
      ;;
    ready)
      shift || true
      ready_command "${repo_root}" "$@"
      ;;
    pair) pair_command "${repo_root}" ;;
    first-run)
      shift || true
      first_run_command "${repo_root}" "$@"
      ;;
    demo)
      shift || true
      demo_command "${repo_root}" "$@"
      ;;
    repair) repair_command "${repo_root}" ;;
    uninstall)
      shift || true
      uninstall_command "${repo_root}" "$@"
      ;;
    update)
      shift || true
      case "${1:-}" in
        "") update_command "${repo_root}" "apply" ;;
        --check | check) update_command "${repo_root}" "check" ;;
        *)
          echo "Usage: mobaile update [--check]" >&2
          exit 1
          ;;
      esac
      ;;
    logs | restart | start | stop) delegate_service_command "${repo_root}" "${command_name}" ;;
    awake) delegate_service_command "${repo_root}" "keep-awake-install" ;;
    awake-status) delegate_service_command "${repo_root}" "keep-awake-status" ;;
    sleep) delegate_service_command "${repo_root}" "keep-awake-uninstall" ;;
    config) config_command "${repo_root}" ;;
    doctor) doctor_command "${repo_root}" ;;
    -h | --help | help) usage ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
