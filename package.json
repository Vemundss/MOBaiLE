{
  "name": "mobaile",
  "private": true,
  "version": "2.0.0",
  "description": "MOBaiLE host-side backend and runtime",
  "license": "FSL-1.1-ALv2",
  "scripts": {
    "backend:lint": "cd backend && uvx ruff check app tests",
    "shell:lint": "bash ./scripts/shell_checks.sh lint",
    "shell:format": "bash ./scripts/shell_checks.sh format",
    "setup:server": "bash ./scripts/bootstrap_server.sh --mode safe",
    "setup:server:full": "bash ./scripts/bootstrap_server.sh --mode full-access",
    "setup:server:auto": "bash ./scripts/bootstrap_server.sh --mode full-access --with-autonomy-stack",
    "backend:install": "bash ./scripts/install_backend.sh --mode safe",
    "backend:install:auto": "bash ./scripts/install_backend.sh --mode full-access --with-autonomy-stack",
    "backend:start": "cd backend && bash ./run_backend.sh",
    "doctor": "bash ./scripts/doctor.sh",
    "pair:qr": "bash ./scripts/pairing_qr.sh",
    "contracts:sync": "cd backend && uv run python ../scripts/sync_contracts.py",
    "contracts:check": "cd backend && uv run python ../scripts/sync_contracts.py --check"
  }
}
