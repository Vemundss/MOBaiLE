{
  "name": "mobaile",
  "private": true,
  "version": "0.1.0",
  "description": "MOBaiLE onboarding and utility command wrappers",
  "scripts": {
    "setup:server": "bash ./scripts/bootstrap_server.sh --mode safe",
    "setup:server:full": "bash ./scripts/bootstrap_server.sh --mode full-access",
    "backend:install": "bash ./scripts/install_backend.sh --mode safe",
    "backend:start": "cd backend && bash ./run_backend.sh",
    "doctor": "bash ./scripts/doctor.sh",
    "pair:qr": "bash ./scripts/pairing_qr.sh",
    "ios:open": "cd ios && open VoiceAgentApp.xcodeproj",
    "ios:generate": "cd ios && xcodegen generate",
    "ios:version": "ruby ./scripts/ios_release_version.rb show",
    "ios:release:setup": "bundle install",
    "ios:release:prepare": "bundle exec fastlane ios prepare",
    "ios:release:testflight": "bundle exec fastlane ios beta",
    "ios:release:appstore": "bundle exec fastlane ios release",
    "contracts:sync": "cd backend && uv run python ../scripts/sync_contracts.py",
    "contracts:check": "cd backend && uv run python ../scripts/sync_contracts.py --check"
  }
}
